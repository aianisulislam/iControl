    <header>
      <div>
        <div class="header-button flex" id="settings" title="Settings">
          <svg style="inline-size: 24px; block-size: 24px">
            <use href="#icon-hamburger"></use>
          </svg>
        </div>
      </div>
      <div style="display: flex">
        <svg style="inline-size: 20px; block-size: 20px">
          <use href="#icon-applogo"></use>
        </svg>
        <h1>iControl</h1>
      </div>
      <div>
        <div class="header-button flex" id="reconnect" title="Reconnect">
          <div class="connection-status flex">
            <div class="dot"></div>
          </div>
        </div>
      </div>
    </header>
    <main>
      <section id="touchpad-wrapper">
        <div id="touchpad" class="touchpad"></div>
        <div id="touchpad-buttons">
          <button data-command='{"type":"click","button":"left"}' id="leftClick"></button>
          <button data-command='{"type":"click","button":"middle"}' id="middleClick"></button>
          <button data-command='{"type":"click","button":"right"}' id="rightClick"></button>
        </div>
      </section>
      <section id="tab-wrapper">
        <div class="tab-title-wrapper flex">
          <div class="tab-title">General</div>
          <div class="tab-title">Type</div>
          <div class="tab-title active">Media</div>
          <div class="tab-title">Apps</div>
          <div class="tab-title">System</div>
        </div>
        <div id="general" class="tab grid grid-4 hidden">
          <button data-command='{"type":"key","key":"tab"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-tab"></use>
            </svg>
            <span class="btn-label">Tab</span>
          </button>
          <button data-command='{"type":"key","key":"up"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-up"></use>
            </svg>
          </button>
          <button data-command='{"type":"key","key":"backspace"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-backspace"></use>
            </svg>
            <span class="btn-label">Delete</span>
          </button>
          <div data-control="setVolume" data-value="60" class="slider row-3">
            <div class="slider-icon">
              <svg style="inline-size: 40px; block-size: 20px">
                <use href="#icon-volume-slider"></use>
              </svg>
            </div>
          </div>
          <button data-command='{"type":"key","key":"left"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-left"></use>
            </svg>
          </button>
          <button data-command='{"type":"key","key":"down"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-down"></use>
            </svg>
          </button>
          <button data-command='{"type":"key","key":"right"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-right"></use>
            </svg>
          </button>
          <button data-modifier="shift" data-toggle>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-shift"></use>
            </svg>
            <span class="btn-label">Shift</span>
          </button>
          <button data-command='{"type":"key","key":"return"}' class="col-2">
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-return"></use>
            </svg>
            <span class="btn-label">Return</span>
          </button>
          <button data-modifier="ctrl" data-toggle>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-ctrl"></use>
            </svg>
            <span class="btn-label">Ctrl</span>
          </button>
          <button data-modifier="opt" data-toggle>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-opt"></use>
            </svg>
            <span class="btn-label">Opt</span>
          </button>
          <button data-modifier="cmd" data-toggle>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-cmd"></use>
            </svg>
            <span class="btn-label">Cmd</span>
          </button>
          <button data-command='{"type":"key","key":"space"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-space"></use>
            </svg>
            <span class="btn-label">Space</span>
          </button>
        </div>
        <div id="type" class="tab grid grid-4 hidden">
          <button data-command='{"type":"key","key":"cmd+a"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">A</span>
            <span class="btn-label">Select All</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+c"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">C</span>
            <span class="btn-label">Copy</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+v"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">V</span>
            <span class="btn-label">Paste</span>
          </button>
          <button data-command='{"type":"key","key":"backspace"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-backspace"></use>
            </svg>
            <span class="btn-label">Delete</span>
          </button>
          <button data-command='{"type":"key","key":"tab"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-tab"></use>
            </svg>
            <span class="btn-label">Tab</span>
          </button>
          <button id="cursorPad" class="col-2">
            <svg style="inline-size: 34px; block-size: 24px">
              <use href="#icon-cursorpad"></use>
            </svg>
            <span class="btn-label">Move cursor</span>
          </button>
          <button data-command='{"type":"key","key":"return"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-return"></use>
            </svg>
            <span class="btn-label">Return</span>
          </button>
          <div class="col-4">
            <textarea id="textInput" placeholder="Type your text here..."></textarea>
          </div>
          <button class="col-2" id="fullKeyboard">Full Keyboard</button>
          <button class="col-2" id="sendText">Send</button>
        </div>
        <div id="media" class="tab flex active">
          <div class="ipod-wheel">
            <button class="wheel-button wheel-button-up" data-command='{"type":"system","action":"volumeUp"}'>
              <svg style="inline-size: 24px; block-size: 24px">
                <use href="#icon-volume-plus"></use>
              </svg>
            </button>
            <button class="wheel-button wheel-button-down" data-command='{"type":"system","action":"volumeDown"}'>
              <svg style="inline-size: 24px; block-size: 24px">
                <use href="#icon-volume-minus"></use>
              </svg>
            </button>
            <button
              class="wheel-button wheel-button-left"
              data-command='{"type":"system","action":"previousTrack"}'
              data-longpress-command='{"type":"key","key":"left"}'
            >
              <svg style="inline-size: 24px; block-size: 24px">
                <use href="#icon-prev-track"></use>
              </svg>
            </button>
            <button
              class="wheel-button wheel-button-right"
              data-command='{"type":"system","action":"nextTrack"}'
              data-longpress-command='{"type":"key","key":"right"}'
            >
              <svg style="inline-size: 24px; block-size: 24px">
                <use href="#icon-next-track"></use>
              </svg>
            </button>
            <button class="wheel-center" data-command='{"type":"system","action":"playPause"}'>
              <svg style="inline-size: 24px; block-size: 24px">
                <use href="#icon-play-pause"></use>
              </svg>
            </button>
          </div>
        </div>
        <div id="apps" class="tab grid grid-4 hidden">
          <button data-command='{"type":"app","app":"Finder"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-finder"></use>
            </svg>
            <span class="btn-label">Finder</span>
          </button>
          <button data-command='{"type":"app","app":"System Settings"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-system-settings"></use>
            </svg>
            <span class="btn-label">Settings</span>
          </button>
          <button data-command='{"type":"app","app":"Safari"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-safari"></use>
            </svg>
            <span class="btn-label">Safari</span>
          </button>
          <button data-command='{"type":"app","app":"App Store"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-app-store"></use>
            </svg>
            <span class="btn-label">App Store</span>
          </button>
          <button data-command='{"type":"app","app":"Calendar"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-calendar"></use>
            </svg>
            <span class="btn-label">Calendar</span>
          </button>
          <button data-command='{"type":"app","app":"Reminders"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-reminders"></use>
            </svg>
            <span class="btn-label">Reminders</span>
          </button>
          <button data-command='{"type":"app","app":"Notes"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-notes"></use>
            </svg>
            <span class="btn-label">Notes</span>
          </button>
          <button data-command='{"type":"app","app":"Photos"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-photos"></use>
            </svg>
            <span class="btn-label">Photos</span>
          </button>
          <button data-command='{"type":"app","app":"Messages"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-messages"></use>
            </svg>
            <span class="btn-label">Messages</span>
          </button>
          <button data-command='{"type":"app","app":"Facetime"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-facetime"></use>
            </svg>
            <span class="btn-label">FaceTime</span>
          </button>
          <button data-command='{"type":"app","app":"Music"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-music"></use>
            </svg>
            <span class="btn-label">Music</span>
          </button>
          <button data-command='{"type":"url","url":"https://www.youtube.com"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-youtube"></use>
            </svg>
            <span class="btn-label">YouTube</span>
          </button>
          <div class="col-3">
            <input type="text" placeholder="App name, bundle id or URL" id="openInput" />
          </div>
          <button id="openButton">Open</button>
        </div>
        <div id="system" class="tab grid grid-4 hidden">
          <button data-command='{"type":"system","action":"missionControl"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-mission-control"></use>
            </svg>
            <span class="btn-label">Mission Ctrl</span>
          </button>
          <button data-command='{"type":"system","action":"launchpad"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-launchpad"></use>
            </svg>
            <span class="btn-label">Launchpad</span>
          </button>
          <button data-command='{"type":"key","key":"ctrl+down"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-expose"></use>
            </svg>
            <span class="btn-label">App Exposé</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+tab"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-window-switch"></use>
            </svg>
            <span class="btn-label">App Switch</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+q"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-close"></use>
            </svg>
            <span class="btn-label">Quit</span>
          </button>
          <button data-command='{"type":"system","action":"minimize"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-minimize"></use>
            </svg>
            <span class="btn-label">Minimize</span>
          </button>
          <button data-command='{"type":"system","action":"fullscreen"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-fullscreen"></use>
            </svg>
            <span class="btn-label">Fullscreen</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+space"}'>
            <svg style="inline-size: 20px; block-size: 20px">
              <use href="#icon-search-circle"></use>
            </svg>
            <span class="btn-label">Spotlight</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+a"}'>
            <svg style="inline-size: 30px; block-size: 30px">
              <use href="#icon-select-all"></use>
            </svg>
            <span class="btn-label">Select All</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+delete"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-cmd-delete"></use>
            </svg>
            <span class="btn-label">Delete</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+c"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-copy"></use>
            </svg>
            <span class="btn-label">Copy</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+v"}'>
            <svg style="inline-size: 22px; block-size: 22px">
              <use href="#icon-paste"></use>
            </svg>
            <span class="btn-label">Paste</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+z"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">Z</span>
            <span class="btn-label">Undo</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+shift+z"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 28px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 18px); inline-size: 12px; block-size: 10px">
              <use href="#icon-shift"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">Z</span>
            <span class="btn-label">Redo</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+n"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">N</span>
            <span class="btn-label">New</span>
          </button>
          <button data-command='{"type":"key","key":"cmd+o"}'>
            <svg style="position: absolute; inset-block-start: 18px; inset-inline-start: calc(50% - 20px); inline-size: 10px; block-size: 10px">
              <use href="#icon-cmd"></use>
            </svg>
            <span style="font-size: 20px; font-weight: 300">O</span>
            <span class="btn-label">Open</span>
          </button>
        </div>
      </section>
      <section class="keyboard hidden" id="keyboard-wrapper">
        <div class="row fn">
          <button class="key label left fluid" data-key="escape">esc</button>
          <button class="key dual" data-action="brightnessDown" data-key="f1">
            <span class="top">
              <svg style="inline-size: 16px; block-size: 20px">
                <use href="#icon-brightness-down"></use>
              </svg>
            </span>
            <span class="bottom">F1</span>
          </button>
          <button class="key dual" data-action="brightnessUp" data-key="f2">
            <span class="top">
              <svg style="inline-size: 18px; block-size: 20px">
                <use href="#icon-brightness-up"></use>
              </svg>
            </span>
            <span class="bottom">F2</span>
          </button>
          <button class="key dual" data-action="missionControl" data-key="f3">
            <span class="top">
              <svg style="inline-size: 20px; block-size: 20px">
                <use href="#icon-mission-control"></use>
              </svg>
            </span>
            <span class="bottom">F3</span>
          </button>
          <button class="key dual" data-action="launchpad" data-key="f4">
            <span class="top">
              <svg style="inline-size: 20px; block-size: 20px">
                <use href="#icon-launchpad"></use>
              </svg>
            </span>
            <span class="bottom">F4</span>
          </button>
          <button class="key dual" data-action="siri" data-key="f5">
            <span class="top">
              <svg style="inline-size: 16px; block-size: 20px">
                <use href="#icon-siri"></use>
              </svg>
            </span>
            <span class="bottom">F5</span>
          </button>
          <button class="key dual" data-action="screenshot" data-key="f6">
            <span class="top">
              <svg style="inline-size: 16px; block-size: 20px">
                <use href="#icon-screenshot"></use>
              </svg>
            </span>
            <span class="bottom">F6</span>
          </button>
          <button class="key dual" data-action="previousTrack" data-key="f7">
            <span class="top">
              <svg style="inline-size: 20px; block-size: 20px">
                <use href="#icon-backward"></use>
              </svg>
            </span>
            <span class="bottom">F7</span>
          </button>
          <button class="key dual" data-action="playPause" data-key="f8">
            <span class="top">
              <svg style="inline-size: 20px; block-size: 20px">
                <use href="#icon-play"></use>
              </svg>
            </span>
            <span class="bottom">F8</span>
          </button>
          <button class="key dual" data-action="nextTrack" data-key="f9">
            <span class="top">
              <svg style="inline-size: 20px; block-size: 20px">
                <use href="#icon-forward"></use>
              </svg>
            </span>
            <span class="bottom">F9</span>
          </button>
          <button class="key dual" data-action="mute" data-key="f10">
            <span class="top">
              <svg style="inline-size: 12px; block-size: 20px">
                <use href="#icon-speaker"></use>
              </svg>
            </span>
            <span class="bottom">F10</span>
          </button>
          <button class="key dual" data-action="volumeDown" data-key="f11">
            <span class="top">
              <svg style="inline-size: 16px; block-size: 20px">
                <use href="#icon-speaker-down"></use>
              </svg>
            </span>
            <span class="bottom">F11</span>
          </button>
          <button class="key dual" data-action="volumeUp" data-key="f12">
            <span class="top">
              <svg style="inline-size: 24px; block-size: 20px">
                <use href="#icon-speaker-up"></use>
              </svg>
            </span>
            <span class="bottom">F12</span>
          </button>
          <button class="key label right" id="closeFullKeyboard">
            <span>close</span>
            <svg style="inline-size: 18px; block-size: 24px">
              <use href="#icon-up-down"></use>
            </svg>
          </button>
        </div>
        <div class="row">
          <button class="key dual fluid" data-n="`" data-s="~">
            <span class="top">~</span>
            <span class="bottom">`</span>
          </button>
          <button class="key dual" data-n="1" data-s="!">
            <span class="top">!</span>
            <span class="bottom">1</span>
          </button>
          <button class="key dual" data-n="2" data-s="@">
            <span class="top">@</span>
            <span class="bottom">2</span>
          </button>
          <button class="key dual" data-n="3" data-s="#">
            <span class="top">#</span>
            <span class="bottom">3</span>
          </button>
          <button class="key dual" data-n="4" data-s="$">
            <span class="top">$</span>
            <span class="bottom">4</span>
          </button>
          <button class="key dual" data-n="5" data-s="%">
            <span class="top">%</span>
            <span class="bottom">5</span>
          </button>
          <button class="key dual" data-n="6" data-s="^">
            <span class="top">^</span>
            <span class="bottom">6</span>
          </button>
          <button class="key dual" data-n="7" data-s="&">
            <span class="top">&</span>
            <span class="bottom">7</span>
          </button>
          <button class="key dual" data-n="8" data-s="*">
            <span class="top">*</span>
            <span class="bottom">8</span>
          </button>
          <button class="key dual" data-n="9" data-s="(">
            <span class="top">(</span>
            <span class="bottom">9</span>
          </button>
          <button class="key dual" data-n="0" data-s=")">
            <span class="top">)</span>
            <span class="bottom">0</span>
          </button>
          <button class="key dual" data-n="-" data-s="_">
            <span class="top">_</span>
            <span class="bottom">-</span>
          </button>
          <button class="key dual" data-n="=" data-s="+">
            <span class="top">+</span>
            <span class="bottom">=</span>
          </button>
          <button class="key one-and-half label right" data-key="delete">delete</button>
        </div>
        <div class="row">
          <button class="key fluid label left" data-key="tab">tab</button>
          <button class="key letter" data-n="q" data-s="Q">q</button>
          <button class="key letter" data-n="w" data-s="W">w</button>
          <button class="key letter" data-n="e" data-s="E">e</button>
          <button class="key letter" data-n="r" data-s="R">r</button>
          <button class="key letter" data-n="t" data-s="T">t</button>
          <button class="key letter" data-n="y" data-s="Y">y</button>
          <button class="key letter" data-n="u" data-s="U">u</button>
          <button class="key letter" data-n="i" data-s="I">i</button>
          <button class="key letter" data-n="o" data-s="O">o</button>
          <button class="key letter" data-n="p" data-s="P">p</button>
          <button class="key dual" data-n="[" data-s="{">
            <span class="top">{</span>
            <span class="bottom">[</span>
          </button>
          <button class="key dual" data-n="]" data-s="}">
            <span class="top">}</span>
            <span class="bottom">]</span>
          </button>
          <button class="key dual" data-n="\" data-s="|">
            <span class="top">|</span>
            <span class="bottom">\</span>
          </button>
        </div>
        <div class="row">
          <button class="key fluid label left" data-kb-modifier="caps">
            <span class="key-label-long">caps lock</span>
            <span class="key-label-short">caps</span>
            <div style="width: 4px; height: 4px; border-radius: 50%; background-color: currentColor"></div>
          </button>
          <button class="key letter" data-n="a" data-s="A">a</button>
          <button class="key letter" data-n="s" data-s="S">s</button>
          <button class="key letter" data-n="d" data-s="D">d</button>
          <button class="key letter" data-n="f" data-s="F">f</button>
          <button class="key letter" data-n="g" data-s="G">g</button>
          <button class="key letter" data-n="h" data-s="H">h</button>
          <button class="key letter" data-n="j" data-s="J">j</button>
          <button class="key letter" data-n="k" data-s="K">k</button>
          <button class="key letter" data-n="l" data-s="L">l</button>
          <button class="key dual" data-n=":" data-s=";">
            <span class="top">:</span>
            <span class="bottom">;</span>
          </button>
          <button class="key dual" data-n="'" data-s='"'>
            <span class="top">"</span>
            <span class="bottom">'</span>
          </button>
          <button class="key one-and-half label right" data-key="return">return</button>
        </div>
        <div class="row">
          <button class="key fluid label left" data-kb-modifier="shift">shift</button>
          <button class="key letter" data-n="z" data-s="Z">z</button>
          <button class="key letter" data-n="x" data-s="X">x</button>
          <button class="key letter" data-n="c" data-s="C">c</button>
          <button class="key letter" data-n="v" data-s="V">v</button>
          <button class="key letter" data-n="b" data-s="B">b</button>
          <button class="key letter" data-n="n" data-s="N">n</button>
          <button class="key letter" data-n="m" data-s="M">m</button>
          <button class="key dual" data-n="," data-s="<">
            <span class="top">&lt;</span>
            <span class="bottom">,</span>
          </button>
          <button class="key dual" data-n="." data-s=">">
            <span class="top">&gt;</span>
            <span class="bottom">.</span>
          </button>
          <button class="key dual" data-n="/" data-s="?">
            <span class="top">?</span>
            <span class="bottom">/</span>
          </button>
          <button class="key" data-key="up">↑</button>
          <button class="key label right" data-kb-modifier="shift">shift</button>
        </div>
        <div class="row">
          <button class="key label left" data-kb-modifier="fn">fn</button>
          <button class="key label left" data-kb-modifier="ctrl">
            <span class="key-label-long">control</span>
            <span class="key-label-short">ctrl</span>
            <svg style="inline-size: 18px; block-size: 16px">
              <use href="#icon-ctrl"></use>
            </svg>
          </button>
          <button class="key label left" data-kb-modifier="opt">
            <span class="key-label-long">option</span>
            <span class="key-label-short">opt</span>
            <svg style="inline-size: 20px; block-size: 16px">
              <use href="#icon-opt"></use>
            </svg>
          </button>
          <button class="key cmd label left" data-kb-modifier="cmd">
            <span class="key-label-long">command</span>
            <span class="key-label-short">cmd</span>
            <svg style="inline-size: 20px; block-size: 16px">
              <use href="#icon-cmd"></use>
            </svg>
          </button>
          <button class="key fluid" data-n=" " data-s=" "></button>
          <button class="key cmd label right" data-kb-modifier="cmd">
            <span class="key-label-long">command</span>
            <span class="key-label-short">cmd</span>
            <svg style="inline-size: 20px; block-size: 16px">
              <use href="#icon-cmd"></use>
            </svg>
          </button>
          <button class="key label right" data-kb-modifier="opt">
            <span class="key-label-long">option</span>
            <span class="key-label-short">opt</span>
            <svg style="inline-size: 20px; block-size: 16px">
              <use href="#icon-opt"></use>
            </svg>
          </button>
          <button class="key" data-key="left">←</button>
          <button class="key" data-key="down">↓</button>
          <button class="key" data-key="right">→</button>
        </div>
      </section>
    </main>
    <div id="drawer-overlay" class="hidden"></div>
    <aside id="settings-drawer">
      <div id="drawer-header">
        <h1 id="drawer-title">Settings</h1>
        <button id="drawer-close">
          <svg style="inline-size: 20px; block-size: 20px">
            <use href="#icon-close"></use>
          </svg>
        </button>
      </div>
      <div class="drawer-section">
        <label class="drawer-label" for="sensitivity-touchpad">
          <span>Touchpad</span>
          <span class="drawer-value" id="val-touchpad">1x</span>
        </label>
        <input type="range" id="sensitivity-touchpad" min="0.25" max="4" step="0.25" value="1" />
        <label class="drawer-label" for="sensitivity-scroll">
          <span>Scroll</span>
          <span class="drawer-value" id="val-scroll">1x</span>
        </label>
        <input type="range" id="sensitivity-scroll" min="0.25" max="4" step="0.25" value="1" />
        <label class="drawer-label" for="sensitivity-cursorpad">
          <span>Cursorpad</span>
          <span class="drawer-value" id="val-cursorpad">1x</span>
        </label>
        <input type="range" id="sensitivity-cursorpad" min="0.25" max="4" step="0.25" value="1" />
      </div>
    </aside>
    <div id="auth-modal" class="hidden">
      <div id="auth-modal-inner">
        <div style="display: flex">
          <svg style="inline-size: 20px; block-size: 20px">
            <use href="#icon-applogo"></use>
          </svg>
          <h1>iControl</h1>
        </div>
        <p id="auth-modal-title">Enter the 4 digit access token to connect</p>
        <div id="auth-token-input">
          <input class="otp-digit" type="text" maxlength="1" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false" />
          <input class="otp-digit" type="text" maxlength="1" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false" />
          <input class="otp-digit" type="text" maxlength="1" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false" />
          <input class="otp-digit" type="text" maxlength="1" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false" />
        </div>
        <p id="auth-error-message" class="hidden"></p>
        <button id="auth-submit">Connect</button>
        <small id="or">OR</small>
        <button id="auth-request">Request Access</button>
      </div>
    </div>
    <script>
      const ICONTROL_HMAC_KEY = "ICONTROL_HMAC_KEY";
      window.addEventListener("contextmenu", (e) => e.preventDefault());
      /* ── Auth: strip token from URL and store in localStorage ── */
      (function () {
        const urlParams = new URLSearchParams(window.location.search);
        const urlToken = urlParams.get("token");
        if (urlToken) {
          localStorage.setItem("icontrol-token", urlToken);
          history.replaceState({}, "", window.location.pathname);
        }
      })();

      const getDeviceName = () => {
        const ua = navigator.userAgent;
        const isTouch = navigator.maxTouchPoints > 1;

        if (/iPhone/.test(ua)) return "iPhone";
        if (/iPad/.test(ua) || (isTouch && /Macintosh/.test(ua))) return "iPad";
        if (/Android/.test(ua)) return "Android Device";
        if (/Macintosh/.test(ua)) return "Mac";
        if (/Windows/.test(ua)) return "Windows PC";
        return "Unknown Device";
      };

      const showAuthModal = (denied = false, errorMsg = "") => {
        const modal = document.getElementById("auth-modal");
        const title = document.getElementById("auth-modal-title");
        const input = document.getElementById("auth-token-input");
        const errorEl = document.getElementById("auth-error-message");
        const submitBtn = document.getElementById("auth-submit");
        const orEl = document.getElementById("or");
        const requestBtn = document.getElementById("auth-request");
        if (denied) {
          errorEl.textContent = "Connection denied by the host.";
          title.classList.add("hidden");
          input.classList.add("hidden");
          submitBtn.classList.add("hidden");
          orEl.classList.add("hidden");
          requestBtn.classList.add("hidden");
        } else {
          title.classList.remove("hidden");
          if (errorMsg) {
            errorEl.classList.remove("hidden");
            errorEl.textContent = errorMsg;
          } else {
            errorEl.classList.add("hidden");
            errorEl.textContent = "";
          }
          input.classList.remove("hidden");
          submitBtn.classList.remove("hidden");
          orEl.classList.remove("hidden");
          requestBtn.classList.remove("hidden");
        }
        modal.classList.remove("hidden");
        if (!denied) input.querySelector(".otp-digit").focus();
      };

      const hideAuthModal = () => {
        document.getElementById("auth-modal").classList.add("hidden");
      };
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

      const inputFeedback = () => {
        navigator?.vibrate?.(15);
        if (audioCtx.state === "suspended") audioCtx.resume();
        const now = audioCtx.currentTime;
        const osc = audioCtx.createOscillator();
        osc.type = "sine";
        osc.frequency.setValueAtTime(600, now);
        const gain = audioCtx.createGain();
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(0.2, now + 0.001);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.03);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start(now);
        osc.stop(now + 0.01);
      };

      const resumeAudio = () => {
        if (audioCtx.state === "suspended") audioCtx.resume();
      };

      document.addEventListener("touchstart", resumeAudio, { passive: true });
      document.addEventListener("click", resumeAudio, { passive: true });

      const status = document.getElementById("reconnect");
      let socket;
      let modifiers = {
        shift: false,
        ctrl: false,
        opt: false,
        cmd: false,
      };

      let activeTab = localStorage.getItem("active-tab") ?? "media";

      let touchpadSensitivity = parseFloat(localStorage.getItem("sens-touchpad") ?? "1");
      let scrollSensitivity = parseFloat(localStorage.getItem("sens-scroll") ?? "1");
      let cursorpadSensitivity = parseFloat(localStorage.getItem("sens-cursorpad") ?? "1");

      /* ====================================
       * Connection handling
       * ==================================== */

      let connectingPromise = null;
      let reconnectAttempts = 0;
      let lastSentToken = "";
      const MAX_RECONNECT = 5;
      const encoder = new TextEncoder();
      let hmacSigningKeyPromise = null;

      const toBase64 = (arrayBuffer) => {
        let binary = "";
        const bytes = new Uint8Array(arrayBuffer);
        const chunkSize = 0x8000;
        for (let i = 0; i < bytes.length; i += chunkSize) {
          const chunk = bytes.subarray(i, i + chunkSize);
          binary += String.fromCharCode(...chunk);
        }
        return btoa(binary);
      };

      /* ====================================
       * Pure JS HMAC-SHA256
       * No Web Crypto API — works on HTTP
       * ==================================== */
      const HMAC = (() => {
        const K = [
          0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5, 0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
          0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174, 0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
          0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967, 0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
          0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85, 0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
          0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3, 0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
          0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
        ];

        const H0 = [0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a, 0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19];

        const rotr = (x, n) => (x >>> n) | (x << (32 - n));
        const add = (...args) => args.reduce((a, b) => (a + b) >>> 0);

        const sha256 = (msgBytes) => {
          const msg = Array.from(msgBytes);
          const bitLen = msg.length * 8;
          msg.push(0x80);
          while (msg.length % 64 !== 56) msg.push(0);
          for (let i = 7; i >= 0; i--) msg.push((bitLen / Math.pow(2, i * 8)) & 0xff);

          let [a0, b0, c0, d0, e0, f0, g0, h0] = H0;

          for (let i = 0; i < msg.length; i += 64) {
            const w = [];
            for (let j = 0; j < 16; j++) {
              w[j] = (msg[i + j * 4] << 24) | (msg[i + j * 4 + 1] << 16) | (msg[i + j * 4 + 2] << 8) | msg[i + j * 4 + 3];
            }
            for (let j = 16; j < 64; j++) {
              const s0 = rotr(w[j - 15], 7) ^ rotr(w[j - 15], 18) ^ (w[j - 15] >>> 3);
              const s1 = rotr(w[j - 2], 17) ^ rotr(w[j - 2], 19) ^ (w[j - 2] >>> 10);
              w[j] = add(w[j - 16], s0, w[j - 7], s1);
            }

            let [a, b, c, d, e, f, g, h] = [a0, b0, c0, d0, e0, f0, g0, h0];

            for (let j = 0; j < 64; j++) {
              const S1 = rotr(e, 6) ^ rotr(e, 11) ^ rotr(e, 25);
              const ch = (e & f) ^ (~e & g);
              const t1 = add(h, S1, ch, K[j], w[j]);
              const S0 = rotr(a, 2) ^ rotr(a, 13) ^ rotr(a, 22);
              const maj = (a & b) ^ (a & c) ^ (b & c);
              const t2 = add(S0, maj);
              [h, g, f, e, d, c, b, a] = [g, f, e, add(d, t1), c, b, a, add(t1, t2)];
            }

            [a0, b0, c0, d0, e0, f0, g0, h0] = [add(a0, a), add(b0, b), add(c0, c), add(d0, d), add(e0, e), add(f0, f), add(g0, g), add(h0, h)];
          }

          return [a0, b0, c0, d0, e0, f0, g0, h0].flatMap((x) => [(x >>> 24) & 0xff, (x >>> 16) & 0xff, (x >>> 8) & 0xff, x & 0xff]);
        };

        const strToBytes = (str) => Array.from(new TextEncoder().encode(str));

        const sign = (message, key) => {
          const keyBytes = strToBytes(key);
          const blockSize = 64;

          let k = keyBytes.length > blockSize ? sha256(keyBytes) : keyBytes;
          while (k.length < blockSize) k.push(0);

          const ipad = k.map((b) => b ^ 0x36);
          const opad = k.map((b) => b ^ 0x5c);

          const msgBytes = strToBytes(message);
          const inner = sha256([...ipad, ...msgBytes]);
          const outer = sha256([...opad, ...inner]);

          return btoa(String.fromCharCode(...outer));
        };

        return { sign };
      })();

      const buildSignedFrame = (payload) => {
          const payloadJSON = JSON.stringify(payload);
          const signature = HMAC.sign(payloadJSON, ICONTROL_HMAC_KEY);
          return JSON.stringify({ p: payload, s: signature });
      };

      const isDenied = () => sessionStorage.getItem("icontrol-denied") === "1";
      const connectWebSocket = () => {
        if (isDenied()) return Promise.resolve();
        if (connectingPromise) return connectingPromise;
        connectingPromise = new Promise((resolve, reject) => {
          socket = new WebSocket(`ws://${location.host}/`);

          socket.addEventListener("open", () => {
            status.style.color = "#22c55e";
            connectingPromise = null;
            reconnectAttempts = 0;
            resolve();
            const token = sessionStorage.getItem("icontrol-session") || localStorage.getItem("icontrol-token") || "";
            lastSentToken = token;
            send({ type: "auth", token, device: getDeviceName() });
          });

          socket.addEventListener("close", () => {
            status.style.color = "#f87171";
            connectingPromise = null;
            if (!isDenied() && reconnectAttempts < MAX_RECONNECT) {
              reconnectAttempts++;
              setTimeout(() => connectWebSocket(), 500);
            }
          });

          socket.addEventListener("error", () => {
            status.style.color = "#f87171";
            connectingPromise = null;
            reject();
          });
          socket.addEventListener("message", (event) => {
            let payload;
            try {
              payload = JSON.parse(event.data);
            } catch {
              return;
            }
            if (payload.type === "state") {
              if (payload.volume !== undefined) {
                const volumeSlider = document.querySelector('.slider[data-control="setVolume"]');
                if (volumeSlider) {
                  volumeSlider.dataset.value = payload.volume;
                  const fill = volumeSlider.querySelector(".slider-fill");
                  if (fill) {
                    fill.style.height = payload.volume + "%";
                  }
                }
              }
            } else if (payload.type === "auth:approved") {
              if (payload.session) {
                sessionStorage.setItem("icontrol-session", payload.token);
              } else {
                localStorage.setItem("icontrol-token", payload.token);
              }
              hideAuthModal();
            } else if (payload.type === "auth:rejected") {
              if (payload.reason === "denied") {
                sessionStorage.setItem("icontrol-denied", "1");
                socket.close();
                showAuthModal(true);
              } else {
                showAuthModal(false, lastSentToken ? "Invalid token. Please try again." : "");
              }
            } else if (payload.type === "auth:open") {
              sessionStorage.removeItem("icontrol-session");
              localStorage.removeItem("icontrol-token");
              hideAuthModal();
            } else if (payload.type === "key:expired") {
              window.location.reload();
            }
          });
        });

        return connectingPromise;
      };

      if (isDenied()) {
        showAuthModal(true);
      } else {
        connectWebSocket();
      }
      const checkAndReconnectWebSocket = () => !isDenied() && socket?.readyState !== WebSocket.OPEN && connectWebSocket();
      window.addEventListener("visibilitychange", () => document.visibilityState === "visible" && checkAndReconnectWebSocket());

      const send = (payload) => {
        console.log("Sending command:", payload);
        const sendAction = () => {
          if (!["move", "dragMove", "scroll"].includes(payload.type)) inputFeedback();
          const frame = buildSignedFrame(payload);
          socket.send(frame);
        };
        if (socket?.readyState === WebSocket.OPEN) {
          try {
            sendAction();
          } catch (error) {
            // Zombie OPEN scenario
            socket?.close();
            connectWebSocket().then(sendAction);
          }
        } else {
          connectWebSocket().then(sendAction);
        }
      };

      /* ====================================
       * Initialize the tabs
       * ==================================== */
      const tabTitles = document.querySelectorAll(".tab-title");
      const tabs = document.querySelectorAll(".tab");
      tabTitles.forEach((title, index) => {
        title.addEventListener("click", () => {
          modifiers = {
            shift: false,
            ctrl: false,
            opt: false,
            cmd: false,
          };
          tabTitles.forEach((t, tIdx) => (tIdx === index ? t.classList.add("active") : t.classList.remove("active")));
          tabs.forEach((t, tIdx) => (tIdx === index ? t.classList.remove("hidden") : t.classList.add("hidden")));
          activeTab = title.textContent.trim().toLowerCase();
          localStorage.setItem("active-tab", activeTab);
        });
      });

      // Restore active tab on load
      const savedIndex = [...tabTitles].findIndex((t) => t.textContent.trim().toLowerCase() === activeTab);
      if (savedIndex > 0) {
        tabTitles.forEach((t, i) => (i === savedIndex ? t.classList.add("active") : t.classList.remove("active")));
        tabs.forEach((t, i) => (i === savedIndex ? t.classList.remove("hidden") : t.classList.add("hidden")));
      }

      /* ====================================
       * Initialize the sliders
       * ==================================== */
      const sliders = document.querySelectorAll(".slider");
      sliders.forEach((slider) => {
        const sliderFill = document.createElement("div");
        sliderFill.classList.add("slider-fill");
        sliderFill.style.height = slider.dataset.value + "%";
        slider.appendChild(sliderFill);
        let dragging = false;

        slider.addEventListener("pointerdown", (e) => {
          dragging = true;
          slider.setPointerCapture(e.pointerId);
          slideHandler(e, slider, sliderFill);
        });

        slider.addEventListener("pointermove", (e) => {
          if (!dragging) return;
          slideHandler(e, slider, sliderFill);
        });

        slider.addEventListener("pointerup", (e) => {
          dragging = false;
          slider.releasePointerCapture(e.pointerId);
        });
      });

      const slideHandler = (event, element, fillElement) => {
        const rect = element.getBoundingClientRect();
        let value = 1 - (event.clientY - rect.top) / rect.height;
        value = 100 * Math.max(0, Math.min(1, value));
        fillElement.style.height = value + "%";
        element.dataset.value = value;
        send({
          type: "system",
          action: element.dataset.control,
          value: Math.round(value),
        });
      };

      /* ====================================
       * Initialize the modifiers
       * ==================================== */
      document.querySelectorAll("[data-modifier]").forEach((button) => {
        button.addEventListener("click", () => {
          inputFeedback();
          const mod = button.dataset.modifier;
          modifiers[mod] = !modifiers[mod];
          button.classList.toggle("active", modifiers[mod]);
        });
      });

      /* ====================================
       * Initialize command buttons
       * ==================================== */
      const LONGPRESS_DELAY = 400;
      const LONGPRESS_INTERVAL = 120;

      document.querySelectorAll("[data-command]").forEach((button) => {
        let holdTimer = null;
        let repeatTimer = null;
        let isLongPress = false;

        // Long press — only on buttons that have data-longpress-command
        if (button.dataset.longpressCommand) {
          const startRepeat = () => {
            isLongPress = true;
            const command = JSON.parse(button.dataset.longpressCommand);
            send(command);
            repeatTimer = setInterval(() => send(command), LONGPRESS_INTERVAL);
          };

          const stop = () => {
            clearTimeout(holdTimer);
            clearInterval(repeatTimer);
            holdTimer = null;
            repeatTimer = null;
          };

          button.addEventListener("pointerdown", (e) => {
            isLongPress = false;
            holdTimer = setTimeout(startRepeat, LONGPRESS_DELAY);
          });

          button.addEventListener("pointerup", stop);
          button.addEventListener("pointercancel", stop);
          button.addEventListener("pointerleave", stop);
        }

        // Click — short tap or click, fires normally unless long press consumed it
        button.addEventListener("click", () => {
          if (isLongPress) {
            isLongPress = false;
            return;
          }
          const commandJSON = JSON.parse(button.dataset.command);
          if (commandJSON.type === "key" && activeTab === "general") {
            const modifierPrefix = Object.keys(modifiers)
              .filter((mod) => modifiers[mod])
              .join("+");
            if (modifierPrefix) {
              commandJSON.key = modifierPrefix + "+" + commandJSON.key;
            }
          }
          if (commandJSON.type === "click") {
            const f = getActiveFlags();
            if (f.shift || f.ctrl || f.opt || f.cmd) commandJSON.flags = f;
          }
          send(commandJSON);
        });
      });

      /* ====================================
       * Initialize the text input
       * ==================================== */
      const sendText = document.getElementById("sendText");
      const textInput = document.getElementById("textInput");
      sendText.addEventListener("click", () => {
        send({ type: "text", value: textInput.value });
        textInput.value = "";
        textInput.focus();
        return;
      });

      /* ====================================
       * Initialize the open app/URL input
       * ==================================== */
      document.getElementById("openButton").addEventListener("click", () => {
        const openInput = document.getElementById("openInput");
        const value = openInput.value.trim();
        if (!value) return;
        send({ type: "open", target: value });
        openInput.value = "";
      });

      /* ====================================
       * Initialize the full keyboard
       * ==================================== */
      const fullKeyboard = document.getElementById("fullKeyboard");
      const tabWrapper = document.getElementById("tab-wrapper");
      const keyboardWrapper = document.getElementById("keyboard-wrapper");
      function showFullKeyboard() {
        tabWrapper.classList.add("hidden");
        keyboardWrapper.classList.remove("hidden");
        localStorage.setItem("layout", "keyboard");
        reorganizeLayout();
      }
      function showButtonsWrapper() {
        keyboardWrapper.classList.add("hidden");
        tabWrapper.classList.remove("hidden");
        localStorage.setItem("layout", "buttons");
        releaseKbModifiers();
        reorganizeLayout();
      }
      const reorganizeLayout = () => {
        const aspectRatio = window.innerWidth / window.innerHeight;
        if (!keyboardWrapper.classList.contains("hidden") && aspectRatio < 1 && window.innerWidth < 480) {
          document.body.classList.add("vertical-rl");
        } else {
          document.body.classList.remove("vertical-rl");
        }
      };

      fullKeyboard.addEventListener("click", showFullKeyboard);
      if (localStorage.getItem("layout") === "keyboard") {
        showFullKeyboard();
      }

      window.addEventListener("resize", reorganizeLayout);

      /* ====================================
       * Initialize the reconnect button
       * ==================================== */
      status.addEventListener("click", () => {
        checkAndReconnectWebSocket();
      });

      /* ====================================
       * Initialize the touch surface
       * ==================================== */
      /**
       * touchTracker — unified gesture recogniser
       * Abstracts all touch interaction into a single reusable function.
       * Handles: tap, hold, swipe, drag, scroll (two finger),
       *          direction, speed, distance, orientation awareness.
       *
       * @param {HTMLElement} element — target element
       * @param {Object} options — configuration
       * @param {Function} callback — gesture handler
       */
      const touchTracker = (element, options = {}, callback) => {
        const {
          // Thresholds
          tapTimeout = 200, // ms window for multi-tap detection
          holdDuration = 350, // ms before hold is triggered
          dragThreshold = 8, // px movement before tap is cancelled
          swipeThreshold = 30, // px minimum for a swipe to register
          swipeMaxDuration = 400, // ms maximum for a swipe gesture
          swipeAngleTolerance = 45, // degrees tolerance for cardinal direction lock

          // Behaviour flags
          cancelTapOnMove = true, // tap cancelled if pointer moves beyond dragThreshold
          detectTwoFinger = true, // enable two-finger gesture detection
          detectSwipe = true, // enable swipe detection
          detectHold = true, // enable hold detection
          detectDrag = true, // enable drag (hold + move) detection
          orientationAware = true, // auto-rotate dx/dy for vertical-rl layouts
        } = options;

        // ── Internal state ──────────────────────────────────────────────────────────
        let touches = []; // active touch start positions
        let lastPoint = null; // last tracked position
        let tapCount = 0; // consecutive tap counter
        let lastTapTime = 0; // timestamp of last tap end
        let tapTimer = null; // debounce timer for tap resolution
        let holdTimer = null; // timer for hold detection
        let swipeStartTime = 0; // timestamp of touch start (for swipe duration)
        let isDragging = false; // drag mode active
        let hasMoved = false; // has moved beyond dragThreshold
        let isHeld = false; // hold has fired
        let twoFingerStarted = false; // two-finger gesture started
        let twoFingerHasMoved = false; // two fingers moved beyond dragThreshold
        let twoFingerStartPoint = null; // centroid at two-finger start

        // ── Orientation transform ───────────────────────────────────────────────────
        const transformCoords = (dx, dy) => {
          if (!orientationAware) return { dx, dy };
          const isVerticalRL = document.body.classList.contains("vertical-rl");
          return isVerticalRL ? { dx: dy, dy: -dx } : { dx, dy };
        };

        // ── Direction resolver ──────────────────────────────────────────────────────
        const resolveDirection = (dx, dy) => {
          const angle = Math.atan2(dy, dx) * (180 / Math.PI);
          const abs = Math.abs;

          if (abs(dx) > abs(dy)) {
            if (abs(angle) < swipeAngleTolerance || abs(angle) > 180 - swipeAngleTolerance) {
              return dx > 0 ? "right" : "left";
            }
          } else {
            if (abs(angle - 90) < swipeAngleTolerance || abs(angle + 90) < swipeAngleTolerance) {
              return dy > 0 ? "down" : "up";
            }
          }

          // diagonal fallback
          if (dx > 0 && dy < 0) return "up-right";
          if (dx < 0 && dy < 0) return "up-left";
          if (dx > 0 && dy > 0) return "down-right";
          return "down-left";
        };

        // ── Speed calculator ────────────────────────────────────────────────────────
        const calcSpeed = (dx, dy, dt) => {
          if (dt === 0) return 0;
          return Math.sqrt(dx * dx + dy * dy) / dt; // px/ms
        };

        // ── Cleanup ─────────────────────────────────────────────────────────────────
        const reset = () => {
          clearTimeout(holdTimer);
          clearTimeout(tapTimer);
          holdTimer = null;
          isDragging = false;
          hasMoved = false;
          isHeld = false;
          twoFingerStarted = false;
          twoFingerHasMoved = false;
          twoFingerStartPoint = null;
          lastPoint = null;
          touches = [];
        };

        // ── Emit ─────────────────────────────────────────────────────────────────────
        const emit = (type, payload = {}) => {
          callback({ type, ...payload });
        };

        // ── Touch start ──────────────────────────────────────────────────────────────
        const onStart = (e) => {
          touches = Array.from(e.touches).map((t) => ({
            x: t.clientX,
            y: t.clientY,
            id: t.identifier,
          }));

          lastPoint = { x: touches[0].x, y: touches[0].y };
          hasMoved = false;
          isDragging = false;
          isHeld = false;
          swipeStartTime = Date.now();

          clearTimeout(holdTimer);

          if (detectTwoFinger && touches.length === 2) {
            twoFingerStarted = true;
            twoFingerHasMoved = false;
            twoFingerStartPoint = {
              x: (touches[0].x + touches[1].x) / 2,
              y: (touches[0].y + touches[1].y) / 2,
            };
          }

          if ((detectHold || detectDrag) && touches.length === 1) {
            holdTimer = setTimeout(() => {
              if (!hasMoved || !cancelTapOnMove) {
                isHeld = true;
                inputFeedback();
                if (detectDrag) {
                  isDragging = true;
                  emit("dragStart", {
                    x: touches[0].x,
                    y: touches[0].y,
                  });
                } else {
                  emit("hold", {
                    x: touches[0].x,
                    y: touches[0].y,
                  });
                }
              }
            }, holdDuration);
          }
        };

        // ── Touch move ───────────────────────────────────────────────────────────────
        const onMove = (e) => {
          const currentTouches = Array.from(e.touches);
          if (!currentTouches.length || !lastPoint) return;

          // ── Two finger (scroll) ────────────────────────────────────────────────
          if (detectTwoFinger && currentTouches.length >= 2) {
            const avg = {
              x: (currentTouches[0].clientX + currentTouches[1].clientX) / 2,
              y: (currentTouches[0].clientY + currentTouches[1].clientY) / 2,
            };

            const rawDx = avg.x - lastPoint.x;
            const rawDy = avg.y - lastPoint.y;
            const { dx, dy } = transformCoords(rawDx, rawDy);
            const dt = Date.now() - swipeStartTime;

            if (Math.sqrt(rawDx * rawDx + rawDy * rawDy) > dragThreshold) {
              twoFingerHasMoved = true;
            }

            emit("twoFingerMove", {
              dx,
              dy,
              x: avg.x,
              y: avg.y,
              speed: calcSpeed(dx, dy, dt),
              direction: resolveDirection(dx, dy),
            });

            lastPoint = avg;
            return;
          }

          // ── Single finger ──────────────────────────────────────────────────────
          const point = { x: currentTouches[0].clientX, y: currentTouches[0].clientY };
          const rawDx = point.x - lastPoint.x;
          const rawDy = point.y - lastPoint.y;
          const { dx, dy } = transformCoords(rawDx, rawDy);
          const dt = Date.now() - swipeStartTime;
          const dist = Math.sqrt(rawDx * rawDx + rawDy * rawDy);

          if (dist > dragThreshold) {
            hasMoved = true;

            // cancel hold if movement exceeds threshold before hold fires
            if (cancelTapOnMove && holdTimer && !isHeld) {
              clearTimeout(holdTimer);
              holdTimer = null;
            }
          }

          if (isDragging) {
            emit("dragMove", {
              dx,
              dy,
              x: point.x,
              y: point.y,
              speed: calcSpeed(dx, dy, dt),
              direction: resolveDirection(dx, dy),
            });
          } else if (hasMoved) {
            emit("move", {
              dx,
              dy,
              x: point.x,
              y: point.y,
              speed: calcSpeed(dx, dy, dt),
              direction: resolveDirection(dx, dy),
            });
          }

          lastPoint = point;
        };

        // ── Touch end ────────────────────────────────────────────────────────────────
        const onEnd = (e) => {
          clearTimeout(holdTimer);
          holdTimer = null;

          const endTime = Date.now();
          const duration = endTime - swipeStartTime;

          // ── Drag end ───────────────────────────────────────────────────────────
          if (isDragging) {
            isDragging = false;
            emit("dragEnd", {
              x: lastPoint?.x,
              y: lastPoint?.y,
            });
            reset();
            return;
          }

          // ── Swipe ──────────────────────────────────────────────────────────────
          if (detectSwipe && hasMoved && duration < swipeMaxDuration && touches.length === 1 && lastPoint) {
            const totalDx = lastPoint.x - touches[0].x;
            const totalDy = lastPoint.y - touches[0].y;
            const totalDist = Math.sqrt(totalDx * totalDx + totalDy * totalDy);

            if (totalDist >= swipeThreshold) {
              const { dx, dy } = transformCoords(totalDx, totalDy);
              emit("swipe", {
                dx,
                dy,
                distance: totalDist,
                duration,
                direction: resolveDirection(dx, dy),
                speed: calcSpeed(dx, dy, duration),
                startX: touches[0].x,
                startY: touches[0].y,
                endX: lastPoint.x,
                endY: lastPoint.y,
              });
              reset();
              return;
            }
          }

          // ── Two-finger tap ─────────────────────────────────────────────────────
          if (detectTwoFinger && twoFingerStarted && !twoFingerHasMoved && e.touches.length === 0 && touches.length === 2) {
            emit("twoFingerTap", {
              x: twoFingerStartPoint?.x,
              y: twoFingerStartPoint?.y,
              duration,
            });
            reset();
            return;
          }

          // ── Tap ────────────────────────────────────────────────────────────────
          if (!hasMoved && touches.length === 1 && e.touches.length === 0) {
            emit("tap", {
              x: touches[0]?.x,
              y: touches[0]?.y,
              duration,
            });
          }

          reset();
        };

        // ── Cancel ───────────────────────────────────────────────────────────────────
        const onCancel = (e) => {
          if (isDragging) {
            emit("dragEnd", { cancelled: true });
          }
          reset();
        };

        // ── Attach listeners ─────────────────────────────────────────────────────────
        element.addEventListener("touchstart", onStart, { passive: false });
        element.addEventListener("touchmove", onMove, { passive: false });
        element.addEventListener("touchend", onEnd, { passive: false });
        element.addEventListener("touchcancel", onCancel, { passive: false });

        // ── Return detach function ───────────────────────────────────────────────────
        return () => {
          element.removeEventListener("touchstart", onStart);
          element.removeEventListener("touchmove", onMove);
          element.removeEventListener("touchend", onEnd);
          element.removeEventListener("touchcancel", onCancel);
          reset();
        };
      };

      const touchpadEl = document.getElementById("touchpad");
      touchTracker(
        touchpadEl,
        {
          detectDrag: true,
          detectTwoFinger: true,
          detectSwipe: false,
        },
        ({ type, dx, dy, count, direction }) => {
          switch (type) {
            case "move":
              send({ type: "move", dx: dx * touchpadSensitivity, dy: dy * touchpadSensitivity });
              break;
            case "twoFingerMove":
              send({ type: "scroll", dx: dx * scrollSensitivity, dy: dy * scrollSensitivity });
              break;
            case "tap": {
              const f = getActiveFlags();
              const cmd = { type: "click", button: "left" };
              if (f.shift || f.ctrl || f.opt || f.cmd) cmd.flags = f;
              send(cmd);
              break;
            }
            case "twoFingerTap": {
              const f = getActiveFlags();
              const cmd = { type: "click", button: "right" };
              if (f.shift || f.ctrl || f.opt || f.cmd) cmd.flags = f;
              send(cmd);
              break;
            }
            case "dragStart":
              touchpadEl.classList.add("drag-mode");
              send({ type: "mouseDown", button: "left" });
              break;
            case "dragMove":
              send({ type: "dragMove", dx: dx * touchpadSensitivity, dy: dy * touchpadSensitivity });
              break;
            case "dragEnd":
              touchpadEl.classList.remove("drag-mode");
              send({ type: "mouseUp", button: "left" });
              break;
          }
        },
      );

      const middleClickEl = document.getElementById("middleClick");
      touchTracker(
        middleClickEl,
        {
          detectDrag: false,
          detectTwoFinger: false,
          detectSwipe: false,
          detectHold: false,
        },
        ({ type, dx, dy }) => {
          if (type !== "move") return;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist === 0) return;
          const angle = Math.atan2(dy, dx) * (180 / Math.PI);
          const isCardinal = Math.abs(angle) < 22.5 || Math.abs(angle - 90) < 22.5 || Math.abs(angle + 90) < 22.5 || Math.abs(Math.abs(angle) - 180) < 22.5;
          if (!isCardinal) return;
          send({ type: "scroll", dx: dx * scrollSensitivity, dy: dy * scrollSensitivity });
        },
      );

      const cursorPadEl = document.getElementById("cursorPad");
      const BASE_PIXELS_PER_KEY = 12;

      let cursorAccX = 0;
      let cursorAccY = 0;

      const resetCursorAcc = () => {
        cursorAccX = 0;
        cursorAccY = 0;
      };

      touchTracker(
        cursorPadEl,
        {
          detectDrag: true,
          detectTwoFinger: false,
          detectSwipe: false,
        },
        ({ type, dx, dy, direction }) => {
          if (direction?.includes("-")) return;

          switch (type) {
            case "move":
            case "dragMove": {
              const threshold = BASE_PIXELS_PER_KEY / cursorpadSensitivity;
              cursorAccX += dx;
              cursorAccY += dy;

              const key = type === "dragMove" ? `shift+${direction}` : direction;

              while (Math.abs(cursorAccX) >= threshold) {
                send({ type: "key", key: cursorAccX > 0 ? (type === "dragMove" ? "shift+right" : "right") : type === "dragMove" ? "shift+left" : "left" });
                cursorAccX += cursorAccX > 0 ? -threshold : threshold;
              }
              while (Math.abs(cursorAccY) >= threshold) {
                send({ type: "key", key: cursorAccY > 0 ? (type === "dragMove" ? "shift+down" : "down") : type === "dragMove" ? "shift+up" : "up" });
                cursorAccY += cursorAccY > 0 ? -threshold : threshold;
              }
              break;
            }
            case "dragStart":
              resetCursorAcc();
              cursorPadEl.classList.add("select-mode");
              break;
            case "dragEnd":
              resetCursorAcc();
              cursorPadEl.classList.remove("select-mode");
              break;
          }
        },
      );

      let isKeyboardSwapped = false;
      const keyboardControlButtonEl = document.getElementById("closeFullKeyboard");
      keyboardControlButtonEl.addEventListener("click", () => showButtonsWrapper());
      const touchpadWrapper = document.getElementById("touchpad-wrapper");
      touchTracker(
        keyboardControlButtonEl,
        {
          detectDrag: false,
          detectTwoFinger: false,
          detectSwipe: true,
          swipeThreshold: 20,
          holdDuration: 300,
        },
        ({ type, direction }) => {
          switch (type) {
            case "tap":
              showButtonsWrapper();
              break;
            case "swipe":
              if (direction === "up") {
                if (keyboardWrapper.classList.contains("mini")) {
                  keyboardWrapper.classList.remove("mini");
                } else if (!isKeyboardSwapped) {
                  keyboardWrapper.classList.add("swapped");
                  touchpadWrapper.classList.add("swapped");
                  isKeyboardSwapped = true;
                }
              } else if (direction === "down") {
                if (isKeyboardSwapped) {
                  keyboardWrapper.classList.remove("swapped");
                  touchpadWrapper.classList.remove("swapped");
                  isKeyboardSwapped = false;
                } else if (!keyboardWrapper.classList.contains("mini")) {
                  keyboardWrapper.classList.add("mini");
                  releaseKbModifiers();
                }
              }
              break;
            case "hold":
              // future use
              break;
          }
        },
      );

      /* ====================================
       * Keyboard state
       * ==================================== */
      const kb = {
        shift: false, // sticky — releases after one printable key
        caps: false, // toggle — persists
        fn: false, // toggle — switches fn row to F keys
        ctrl: false, // held — sends kb:down / kb:up (future)
        opt: false, // held — sends kb:down / kb:up (future)
        cmd: false, // held — sends kb:down / kb:up (future)
      };

      const getActiveFlags = () => {
        const isKeyboardOpen = !keyboardWrapper.classList.contains("hidden");
        if (isKeyboardOpen) {
          return { shift: kb.shift, ctrl: kb.ctrl, opt: kb.opt, cmd: kb.cmd };
        }
        return { shift: modifiers.shift, ctrl: modifiers.ctrl, opt: modifiers.opt, cmd: modifiers.cmd };
      };

      const kbSend = (payload) => {
        const isPrintable = payload.key?.length === 1;
        const nonShiftModifierActive = kb.cmd || kb.opt || kb.ctrl;
        if (nonShiftModifierActive && payload.key === " ") payload.key = "space";
        send({
          ...payload,
          flags: {
            shift: isPrintable && !nonShiftModifierActive ? false : kb.shift,
            ctrl: kb.ctrl,
            opt: kb.opt,
            cmd: kb.cmd,
          },
        });
      };
      /* ====================================
       * Keyboard UI helpers
       * ==================================== */
      const kbEl = document.getElementById("keyboard-wrapper");

      const updateKbModifierUI = () => {
        // Shift visual
        kbEl.querySelectorAll('[data-kb-modifier="shift"]').forEach((b) => b.classList.toggle("active", kb.shift));

        // Caps visual — also drives letter case via CSS
        kbEl.querySelectorAll('[data-kb-modifier="caps"]').forEach((b) => b.classList.toggle("active", kb.caps));
        kbEl.classList.toggle("caps-active", kb.caps);

        // Fn visual
        kbEl.querySelectorAll('[data-kb-modifier="fn"]').forEach((b) => b.classList.toggle("active", kb.fn));

        // Modifier visuals
        ["ctrl", "opt", "cmd"].forEach((mod) => {
          kbEl.querySelectorAll(`[data-kb-modifier="${mod}"]`).forEach((b) => b.classList.toggle("active", kb[mod]));
        });

        // Letter case driven by shift OR caps — but caps doesn't affect symbols
        kbEl.classList.toggle("shift-active", kb.shift || kb.caps);
      };
      /* ====================================
       * Keyboard modifier clear
       * ==================================== */

      const releaseKbModifiers = () => {
        kb.shift = false;
        kb.caps = false;
        kb.fn = false;
        kb.ctrl = false;
        kb.opt = false;
        kb.cmd = false;
        updateKbModifierUI();
        // when Swift keydown/keyup is ready, send keyup for held modifiers here
      };

      /* ====================================
       * Shift auto-release
       * ==================================== */
      const releaseShift = () => {
        if (kb.shift) {
          kb.shift = false;
          updateKbModifierUI();
        }
      };

      /* ====================================
       * Key dispatch
       * ==================================== */
      const handleKbKey = (button) => {
        const { kbModifier, action, key, n, s } = button.dataset;

        // ── Modifier ────────────────────────────────────────────────────────────
        if (kbModifier) {
          inputFeedback();
          switch (kbModifier) {
            case "shift":
              kb.shift = !kb.shift;
              break;
            case "caps":
              kb.caps = !kb.caps;
              break;
            case "fn":
              kb.fn = !kb.fn;
              break;
            case "ctrl":
            case "opt":
            case "cmd":
              kb[kbModifier] = !kb[kbModifier];
              break;
          }
          updateKbModifierUI();
          return;
        }

        // ── Fn row system action ─────────────────────────────────────────────────
        if (action) {
          if (kb.fn && key) {
            // fn active — send F key instead of system action
            kbSend({ type: "kb", key });
          } else {
            kbSend({ type: "system", action });
          }
          return;
        }

        // ── Named special key ────────────────────────────────────────────────────
        if (key) {
          kbSend({ type: "kb", key });
          // shift passes through to backend via modifier state
          // no auto-release — shift+arrow, shift+return etc need shift held
          return;
        }

        // ── Printable character ──────────────────────────────────────────────────
        if (n !== undefined) {
          // resolve character — shift or caps for letters, shift only for symbols
          const isLetter = button.classList.contains("letter");
          const useShifted = kb.shift || (kb.caps && isLetter);
          const char = useShifted && s ? s : n;

          kbSend({ type: "kb", key: char });

          // auto-release shift after printable key
          releaseShift();
          return;
        }
      };

      /* ====================================
       * Attach keyboard listeners
       * ==================================== */
      kbEl.addEventListener("click", (e) => {
        const button = e.target.closest(".key");
        if (!button || button.id === "closeFullKeyboard") return;
        handleKbKey(button);
      });

      // Desktop testing fallback
      kbEl.querySelectorAll(".key").forEach((key) => {
        if (key.id === "closeFullKeyboard") return;
        key.addEventListener("click", () => {}); // ensures :active fires on desktop
      });
      /* ====================================
       * Settings Drawer
       * ==================================== */
      const settingsDrawer = document.getElementById("settings-drawer");
      const drawerOverlay = document.getElementById("drawer-overlay");

      function openDrawer() {
        document.body.classList.add("drawer-open");
        drawerOverlay.classList.remove("hidden");
      }
      function closeDrawer() {
        document.body.classList.remove("drawer-open");
        drawerOverlay.classList.add("hidden");
      }

      document.getElementById("settings").addEventListener("click", openDrawer);
      document.getElementById("drawer-close").addEventListener("click", closeDrawer);
      drawerOverlay.addEventListener("click", closeDrawer);
      drawerOverlay.addEventListener(
        "touchend",
        (e) => {
          e.preventDefault();
          closeDrawer();
        },
        { passive: false },
      );

      const sensSliders = [
        {
          id: "sensitivity-touchpad",
          valId: "val-touchpad",
          key: "sens-touchpad",
          get: () => touchpadSensitivity,
          set: (v) => {
            touchpadSensitivity = v;
          },
        },
        {
          id: "sensitivity-scroll",
          valId: "val-scroll",
          key: "sens-scroll",
          get: () => scrollSensitivity,
          set: (v) => {
            scrollSensitivity = v;
          },
        },
        {
          id: "sensitivity-cursorpad",
          valId: "val-cursorpad",
          key: "sens-cursorpad",
          get: () => cursorpadSensitivity,
          set: (v) => {
            cursorpadSensitivity = v;
          },
        },
      ];
      sensSliders.forEach(({ id, valId, key, set }) => {
        const slider = document.getElementById(id);
        const label = document.getElementById(valId);
        const stored = localStorage.getItem(key);
        if (stored) slider.value = stored;
        label.textContent = parseFloat(slider.value) + "x";
        slider.addEventListener("input", () => {
          const v = parseFloat(slider.value);
          set(v);
          label.textContent = v + "x";
          localStorage.setItem(key, v);
        });
      });

      /* ── OTP digit box behaviour ── */
      (function () {
        const digits = Array.from(document.querySelectorAll("#auth-token-input .otp-digit"));

        const submitIfComplete = () => {
          const token = digits.map((d) => d.value).join("");
          if (token.length === 4) document.getElementById("auth-submit").click();
        };

        digits.forEach((box, i) => {
          box.addEventListener("focus", () => box.select());

          box.addEventListener("input", (e) => {
            const val = box.value.replace(/[^a-zA-Z0-9]/g, "").toUpperCase();
            box.value = val ? val[val.length - 1] : "";
            if (box.value && i < 3) {
              digits[i + 1].focus();
            }
            submitIfComplete();
          });

          box.addEventListener("keydown", (e) => {
            if (e.key === "Backspace") {
              if (box.value) {
                box.value = "";
              } else if (i > 0) {
                digits[i - 1].focus();
                digits[i - 1].value = "";
              }
              e.preventDefault();
            } else if (e.key === "ArrowLeft" && i > 0) {
              digits[i - 1].focus();
            } else if (e.key === "ArrowRight" && i < 3) {
              digits[i + 1].focus();
            } else if (e.key === "Enter") {
              document.getElementById("auth-submit").click();
            }
          });

          box.addEventListener("paste", (e) => {
            e.preventDefault();
            const text = (e.clipboardData || window.clipboardData)
              .getData("text")
              .replace(/[^a-zA-Z0-9]/g, "")
              .toUpperCase()
              .slice(0, 4);
            text.split("").forEach((ch, j) => {
              if (digits[j]) digits[j].value = ch;
            });
            const nextEmpty = digits.findIndex((d) => !d.value);
            (nextEmpty === -1 ? digits[3] : digits[nextEmpty]).focus();
            submitIfComplete();
          });
        });
      })();

      /* ── Auth modal submit ── */
      document.getElementById("auth-submit").addEventListener("click", () => {
        const digits = document.querySelectorAll("#auth-token-input .otp-digit");
        const enteredToken = Array.from(digits)
          .map((d) => d.value)
          .join("")
          .toUpperCase();
        if (enteredToken.length < 4) return;
        lastSentToken = enteredToken;
        send({ type: "auth", token: enteredToken, device: getDeviceName() });
      });

      document.getElementById("auth-request").addEventListener("click", () => {
        send({ type: "auth:request", device: getDeviceName() });
      });
    </script>
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch((err) => console.error("SW registration failed:", err));
        });
        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data?.type === "UPDATE_AVAILABLE") {
            window.location.reload();
          }
        });
      }
    </script>
  </body>
</html>

§ iControl/Server/HTTPServer.swift
import Foundation
import Network
import CryptoKit
import SystemConfiguration

final class HTTPServer {
    private static let hmacKeyLength = 32
    private static let versionSuffixLength = 10
    private static let randomChars = Array("ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789")
    private let port: UInt16
    private let inputController: InputController
    private let authContext: AuthContext
    private let hmacKey: String
    private let sessionVersionSuffix: String
    private let queue = DispatchQueue(label: "iControl.HTTPServer")
    private var listener: NWListener?
    private var clients: [ObjectIdentifier: ClientConnection] = [:]
    private var webSockets: [ObjectIdentifier: WebSocketServer] = [:]

    init(port: UInt16, inputController: InputController, authContext: AuthContext) {
        self.port = port
        self.inputController = inputController
        self.authContext = authContext
        self.hmacKey = Self.randomAlphanumeric(length: Self.hmacKeyLength)
        self.sessionVersionSuffix = Self.randomAlphanumeric(length: Self.versionSuffixLength)
        self.inputController.onVolumeChanged = { [weak self] volume in
            self?.broadcastVolume(volume)
        }
    }

    func start() {
        guard listener == nil else {
            print("iControl: server already running on port \(port)")
            return
        }

        guard let listenerPort = NWEndpoint.Port(rawValue: port) else {
            print("iControl: invalid port \(port)")
            return
        }

        do {
            let listener = try NWListener(using: .tcp, on: listenerPort)
            listener.stateUpdateHandler = { [weak self] state in
                self?.handleListenerState(state)
            }
            listener.newConnectionHandler = { [weak self] connection in
                self?.accept(connection)
            }
            self.listener = listener
            print("iControl: starting HTTP server on port \(port)")
            listener.start(queue: queue)
        } catch {
            print("iControl: failed to start server on port \(port): \(error)")
        }
    }

    private func handleListenerState(_ state: NWListener.State) {
        switch state {
        case .ready:
            if let endpoint = listener?.port {
                print("iControl: server listening on 0.0.0.0:\(endpoint.rawValue)")
            } else {
                print("iControl: server listener ready")
            }
        case .failed(let error):
            print("iControl: listener failed: \(error)")
        case .cancelled:
            print("iControl: listener cancelled")
        default:
            break
        }
    }

    private func accept(_ connection: NWConnection) {
        let identifier = ObjectIdentifier(connection)
        let client = ClientConnection(connection: connection)
        clients[identifier] = client

        print("iControl: client connected")

        connection.stateUpdateHandler = { [weak self] state in
            self?.handleConnectionState(state, id: identifier)
        }

        connection.start(queue: queue)
        receiveRequest(for: identifier)
    }

    private func handleConnectionState(_ state: NWConnection.State, id: ObjectIdentifier) {
        switch state {
        case .failed(let error):
            print("iControl: client connection failed: \(error)")
            removeConnection(id: id)
        case .cancelled:
            removeConnection(id: id)
        default:
            break
        }
    }

    private func receiveRequest(for id: ObjectIdentifier) {
        guard let client = clients[id] else { return }

        client.connection.receive(minimumIncompleteLength: 1, maximumLength: 4096) { [weak self] data, _, isComplete, error in
            guard let self else { return }

            if let error {
                print("iControl: receive error: \(error)")
                self.removeConnection(id: id)
                return
            }

            if let data, !data.isEmpty {
                client.buffer.append(data)
            }

            if client.buffer.range(of: Data("\r\n\r\n".utf8)) != nil {
                self.handleRequest(client.buffer, for: id)
                return
            }

            if isComplete {
                self.handleRequest(client.buffer, for: id)
                return
            }

            self.receiveRequest(for: id)
        }
    }

    private func handleRequest(_ data: Data, for id: ObjectIdentifier) {
        guard let client = clients[id] else { return }

        guard let request = String(data: data, encoding: .utf8) else {
            print("iControl: invalid request data")
            send(status: "400 Bad Request", body: "Bad Request", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let lines = request.components(separatedBy: "\r\n")
        guard let requestLine = lines.first, !requestLine.isEmpty else {
            print("iControl: missing request line")
            send(status: "400 Bad Request", body: "Bad Request", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        print("iControl: HTTP request received: \(requestLine)")

        let parts = requestLine.split(separator: " ")
        guard parts.count >= 2 else {
            send(status: "400 Bad Request", body: "Bad Request", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let method = String(parts[0])
        let rawPath = String(parts[1])
        let headers = parseHeaders(lines.dropFirst())

        if headers["upgrade"]?.lowercased() == "websocket" {
            print("iControl: WebSocket upgrade attempt")
            upgradeToWebSocket(headers: headers, connectionID: id)
            return
        }

        guard method == "GET" else {
            send(status: "404 Not Found", body: "Not Found", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let path = rawPath.components(separatedBy: "?").first ?? rawPath
        let filePath = (path == "/") ? "/index.html" : path

        guard !filePath.contains("..") else {
            send(status: "403 Forbidden", body: "Forbidden", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let relativePath = String(filePath.dropFirst())
        let url = URL(fileURLWithPath: relativePath)
        let fileName = url.deletingPathExtension().path
        let fileExtension = url.pathExtension

        guard let resourceURL = Bundle.main.url(forResource: fileName, withExtension: fileExtension.isEmpty ? nil : fileExtension),
              let fileData = try? Data(contentsOf: resourceURL) else {
            print("iControl: resource not found: \(relativePath)")
            send(status: "404 Not Found", body: "Not Found", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let responseData: Data
        if relativePath == "index.html" {
            responseData = prepareIndexHTML(data: fileData) ?? fileData
        } else {
            responseData = fileData
        }

        let contentType = mimeType(for: fileExtension)
        print("iControl: serving \(relativePath) (\(contentType))")
        send(status: "200 OK", data: responseData, contentType: contentType, to: client.connection, closeAfterSend: true)
    }

    private func mimeType(for extension: String) -> String {
        switch `extension`.lowercased() {
        case "html":        return "text/html; charset=utf-8"
        case "css":         return "text/css; charset=utf-8"
        case "js":          return "application/javascript; charset=utf-8"
        case "json":        return "application/json"
        case "png":         return "image/png"
        case "jpg", "jpeg": return "image/jpeg"
        case "svg":         return "image/svg+xml"
        case "ico":         return "image/x-icon"
        case "webp":        return "image/webp"
        case "woff":        return "font/woff"
        case "woff2":       return "font/woff2"
        case "webmanifest": return "application/manifest+json"
        default:            return "application/octet-stream"
        }
    }

    private func parseHeaders(_ lines: ArraySlice<String>) -> [String: String] {
        var headers: [String: String] = [:]
        for line in lines where !line.isEmpty {
            let parts = line.split(separator: ":", maxSplits: 1)
            guard parts.count == 2 else { continue }
            headers[String(parts[0]).lowercased()] = parts[1].trimmingCharacters(in: .whitespaces)
        }
        return headers
    }

    private func allowedOrigins() -> Set<String> {
        var origins: Set<String> = ["null"]  // PWA/standalone mode sends Origin: null
        if let hostname = Self.localHostname() {
            origins.insert("http://\(hostname).local:\(port)".lowercased())
        }
        if let ip = Self.localIPAddress() {
            origins.insert("http://\(ip):\(port)")
        }
        return origins
    }

    private static func localHostname() -> String? {
        SCDynamicStoreCopyLocalHostName(nil) as String?
    }

    private static func localIPAddress() -> String? {
        var addr = sockaddr_in()
        addr.sin_family = sa_family_t(AF_INET)
        addr.sin_port = 80
        addr.sin_addr.s_addr = inet_addr("8.8.8.8")

        let sock = socket(AF_INET, SOCK_DGRAM, 0)
        guard sock != -1 else { return nil }
        defer { close(sock) }

        let connected = withUnsafePointer(to: &addr) {
            $0.withMemoryRebound(to: sockaddr.self, capacity: 1) {
                connect(sock, $0, socklen_t(MemoryLayout<sockaddr_in>.size))
            }
        }
        guard connected == 0 else { return nil }

        var local = sockaddr_in()
        var len = socklen_t(MemoryLayout<sockaddr_in>.size)
        let named = withUnsafeMutablePointer(to: &local) {
            $0.withMemoryRebound(to: sockaddr.self, capacity: 1) {
                getsockname(sock, $0, &len)
            }
        }
        guard named == 0 else { return nil }

        var buffer = [CChar](repeating: 0, count: Int(INET_ADDRSTRLEN))
        inet_ntop(AF_INET, &local.sin_addr, &buffer, socklen_t(INET_ADDRSTRLEN))
        return String(cString: buffer)
    }

    private func upgradeToWebSocket(headers: [String: String], connectionID: ObjectIdentifier) {
        guard let client = clients[connectionID] else { return }

        guard let origin = headers["origin"] else {
            print("iControl: WebSocket rejected — missing Origin header")
            send(status: "403 Forbidden", body: "Forbidden", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        guard allowedOrigins().contains(origin.lowercased()) else {
            print("iControl: WebSocket rejected — disallowed origin: \(origin)")
            send(status: "403 Forbidden", body: "Forbidden", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        guard let key = headers["sec-websocket-key"] else {
            send(status: "400 Bad Request", body: "Missing WebSocket Key", contentType: "text/plain", to: client.connection, closeAfterSend: true)
            return
        }

        let accept = websocketAccept(for: key)
        let response =
            "HTTP/1.1 101 Switching Protocols\r\n" +
            "Upgrade: websocket\r\n" +
            "Connection: Upgrade\r\n" +
            "Sec-WebSocket-Accept: \(accept)\r\n" +
            "\r\n"

        client.connection.send(content: Data(response.utf8), completion: .contentProcessed { [weak self] error in
            guard let self else { return }

            if let error {
                print("iControl: WebSocket upgrade failed: \(error)")
                self.removeConnection(id: connectionID)
                return
            }

            print("iControl: WebSocket upgrade succeeded")
            let socket = WebSocketServer(
                connection: client.connection,
                inputController: self.inputController,
                authContext: self.authContext,
                hmacKey: self.hmacKey
            )
            self.webSockets[connectionID] = socket
            socket.start()
        })
    }

    private func prepareIndexHTML(data: Data) -> Data? {
        guard var html = String(data: data, encoding: .utf8) else {
            return nil
        }

        html = html.replacingOccurrences(of: "\"ICONTROL_HMAC_KEY\"", with: "\"\(hmacKey)\"")
        html = appendSessionVersionSuffix(in: html)
        return Data(html.utf8)
    }

    private func appendSessionVersionSuffix(in html: String) -> String {
        guard let regex = try? NSRegularExpression(pattern: "<meta\\s+name=\"version\"\\s+content=\"([^\"]*)\""),
              let match = regex.firstMatch(in: html, range: NSRange(html.startIndex..., in: html)),
              let versionRange = Range(match.range(at: 1), in: html) else {
            return html
        }

        var updated = html
        let baseVersion = String(updated[versionRange])
        updated.replaceSubrange(versionRange, with: "\(baseVersion)_\(sessionVersionSuffix)")
        return updated
    }

    private static func randomAlphanumeric(length: Int) -> String {
        String((0..<length).map { _ in randomChars[Int.random(in: 0..<randomChars.count)] })
    }

    private func websocketAccept(for key: String) -> String {
        let magic = key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
        let hash = Insecure.SHA1.hash(data: Data(magic.utf8))
        return Data(hash).base64EncodedString()
    }

    private func send(status: String, body: String, contentType: String, to connection: NWConnection, closeAfterSend: Bool) {
        send(status: status, data: Data(body.utf8), contentType: contentType, to: connection, closeAfterSend: closeAfterSend)
    }

    private func send(status: String, data: Data, contentType: String, to connection: NWConnection, closeAfterSend: Bool) {
        let response =
            "HTTP/1.1 \(status)\r\n" +
            "Content-Type: \(contentType)\r\n" +
            "Content-Length: \(data.count)\r\n" +
            "Connection: \(closeAfterSend ? "close" : "keep-alive")\r\n" +
            "\r\n"

        var packet = Data(response.utf8)
        packet.append(data)

        connection.send(content: packet, completion: .contentProcessed { [weak self] error in
            if let error {
                print("iControl: send failed: \(error)")
            }
            if closeAfterSend {
                connection.cancel()
            }
            if closeAfterSend, let self {
                self.removeConnection(id: ObjectIdentifier(connection))
            }
        })
    }

    private func removeConnection(id: ObjectIdentifier) {
        clients[id] = nil
        webSockets[id] = nil
    }

    func disconnectAllWebSockets() {
        queue.async { [weak self] in
            guard let self else { return }
            for socket in self.webSockets.values {
                socket.disconnect()
            }
            self.webSockets = [:]
        }
    }

    private func broadcastVolume(_ volume: Double) {
        queue.async { [weak self] in
            guard let self else { return }
            for socket in self.webSockets.values {
                socket.sendState(volume: volume)
            }
        }
    }
}

private final class ClientConnection {
    let connection: NWConnection
    var buffer = Data()

    init(connection: NWConnection) {
        self.connection = connection
    }
}

§ iControl/Server/WebSocketServer.swift
import AppKit
import CryptoKit
import Foundation
import Network


struct KbFlags: Codable {
    let shift: Bool?
    let ctrl: Bool?
    let opt: Bool?
    let cmd: Bool?
}

struct RemoteCommand: Decodable {
    let type: String
    let key: String?
    let url: String?
    let target: String?
    let value: CommandValue?
    let button: String?
    let action: String?
    let app: String?
    let dx: Double?
    let dy: Double?
    let flags: KbFlags?
    let token: String?
    let device: String?
}

enum CommandValue: Decodable {
    case string(String)
    case number(Double)

    var stringValue: String? {
        if case let .string(value) = self {
            return value
        }
        return nil
    }

    var numberValue: Double? {
        if case let .number(value) = self {
            return value
        }
        return nil
    }

    init(from decoder: Decoder) throws {
        let container = try decoder.singleValueContainer()

        if let string = try? container.decode(String.self) {
            self = .string(string)
            return
        }

        self = .number(try container.decode(Double.self))
    }
}

enum ConnectionAuthState {
    case pending
    case approved
}

final class WebSocketServer {
    private static let maxFramePayloadBytes = 1_048_576
    private static let maxNonTextPayloadBytes = 4_096
    private static let rateLimitWindowSeconds: TimeInterval = 1
    private static let maxCommandsPerWindow = 120

    private let connection: NWConnection
    private let inputController: InputController
    private let authContext: AuthContext
    private let hmacKey: SymmetricKey
    private var authState: ConnectionAuthState = .pending
    private var commandCount = 0
    private var windowStart = Date()

    init(connection: NWConnection, inputController: InputController, authContext: AuthContext, hmacKey: String) {
        self.connection = connection
        self.inputController = inputController
        self.authContext = authContext
        self.hmacKey = SymmetricKey(data: Data(hmacKey.utf8))
    }

    func start() {
        if authContext.mode == "open" {
            authState = .approved
            sendMessage(#"{"type":"auth:open"}"#)
        }
        sendInitialState()
        receiveFrame()
    }

    func disconnect() {
        sendFrame(opcode: 0x8, payload: Data())
        connection.cancel()
    }

    func sendState(volume: Double) {
        let roundedVolume = Int(volume.rounded())
        let payload = #"{"type":"state","volume":\#(roundedVolume)}"#
        sendFrame(opcode: 0x1, payload: Data(payload.utf8))
    }

    private func receiveFrame() {
        connection.receive(minimumIncompleteLength: 2, maximumLength: Self.maxFramePayloadBytes + 32) { [weak self] data, _, isComplete, error in
            guard let self else {
                return
            }

            if let data, !data.isEmpty {
                self.handleFrame(data)
            }

            if error == nil && !isComplete {
                self.receiveFrame()
            }
        }
    }

    private func handleFrame(_ data: Data) {
        guard let frame = decodeFrame(data) else {
            return
        }

        switch frame.opcode {
        case 0x1:
            handleText(frame.payload)
        case 0x8:
            connection.cancel()
        case 0x9:
            sendFrame(opcode: 0xA, payload: frame.payload)
        default:
            break
        }
    }

    private func handleText(_ payload: Data) {
        let unwrapResult = unwrapAndVerifySignedPayload(payload)
        switch unwrapResult {
        case .malformed:
            return
        case .signatureMismatch:
            sendMessage(#"{"type":"key:expired"}"#)
            return
        case .valid(let verifiedPayload):
            guard let command = try? JSONDecoder().decode(RemoteCommand.self, from: verifiedPayload) else {
                return
            }

            if command.type != "text", verifiedPayload.count > Self.maxNonTextPayloadBytes {
                return
            }

            if shouldRateLimit() {
                return
            }

            // Gate on auth state — only auth messages pass while pending
            if authState == .pending {
                switch command.type {
                case "auth":
                    handleAuthMessage(command)
                case "auth:request":
                    handleAuthRequest(command)
                default:
                    break
                }
                return
            }

            // Approved: dispatch normal commands
            switch command.type {
            case "key":
                if let key = command.key {
                    inputController.pressKey(key: key)
                }
            case "text":
                if let value = command.value?.stringValue {
                    inputController.typeText(string: value)
                }
            case "click":
                inputController.mouseClick(button: command.button ?? "left", flags: command.flags)
            case "mouseDown":
                inputController.mouseDown(button: command.button ?? "left")
            case "mouseUp":
                inputController.mouseUp(button: command.button ?? "left")
            case "dragMove":
                inputController.dragMouse(dx: command.dx ?? 0, dy: command.dy ?? 0)
            case "move":
                inputController.moveMouse(dx: command.dx ?? 0, dy: command.dy ?? 0)
            case "scroll":
                inputController.scroll(dx: command.dx ?? 0, dy: command.dy ?? 0)
            case "system":
                if let action = command.action {
                    inputController.performSystemAction(action, value: command.value?.numberValue)
                }
            case "app":
                if let app = command.app {
                    inputController.launchApp(app)
                }
            case "url":
                if let url = command.url {
                    inputController.openURL(url)
                }
            case "open":
                if let target = command.target {
                    inputController.openTarget(target)
                }
            case "kb":
                if let key = command.key {
                    inputController.handleKbInput(key, flags: command.flags)
                }
            case "auth":
                if authContext.mode == "open" {
                    sendMessage(#"{"type":"auth:open"}"#)
                }
            default:
                break
            }
        }
    }

    // MARK: - Auth message handling

    private func handleAuthMessage(_ command: RemoteCommand) {
        let token = command.token ?? ""

        guard authContext.isWellFormed(token) else {
            sendMessage(#"{"type":"auth:rejected","reason":"invalid_token"}"#)
            return
        }

        if authContext.isTokenValid(token) {
            authState = .approved
            let safeToken = token.replacingOccurrences(of: "\"", with: "")
            sendMessage(#"{"type":"auth:approved","token":"\#(safeToken)","session":false}"#)
        } else {
            sendMessage(#"{"type":"auth:rejected","reason":"invalid_token"}"#)
        }
    }

    private func handleAuthRequest(_ command: RemoteCommand) {
        let deviceName = command.device ?? "Unknown Device"

        DispatchQueue.main.async { [weak self] in
            guard let self else { return }

            let alert = NSAlert()
            alert.messageText = "Connection Request"
            alert.informativeText = "\(deviceName) wants to control your Mac via iControl."
            alert.addButton(withTitle: "Allow")
            alert.addButton(withTitle: "Deny")
            alert.alertStyle = .warning
            let response = alert.runModal()

            if response == .alertFirstButtonReturn {
                let sessionToken = AuthContext.generateToken()
                self.authContext.approvedSessions.insert(sessionToken)
                self.authState = .approved
                self.sendMessage(#"{"type":"auth:approved","token":"\#(sessionToken)","session":true}"#)
            } else {
                self.sendMessage(#"{"type":"auth:rejected","reason":"denied"}"#)
            }
        }
    }

    // MARK: - Frame helpers

    private func sendMessage(_ text: String) {
        sendFrame(opcode: 0x1, payload: Data(text.utf8))
    }

    private func sendFrame(opcode: UInt8, payload: Data) {
        var frame = Data()
        frame.append(0x80 | opcode)

        if payload.count < 126 {
            frame.append(UInt8(payload.count))
        } else if payload.count <= 65_535 {
            frame.append(126)
            frame.append(UInt8((payload.count >> 8) & 0xFF))
            frame.append(UInt8(payload.count & 0xFF))
        } else {
            frame.append(127)
            for shift in stride(from: 56, through: 0, by: -8) {
                frame.append(UInt8((UInt64(payload.count) >> UInt64(shift)) & 0xFF))
            }
        }

        frame.append(payload)
        connection.send(content: frame, completion: .contentProcessed { _ in })
    }

    private func sendInitialState() {
        guard let volume = inputController.currentVolumePercentage() else {
            return
        }

        sendState(volume: volume)
    }

    private func decodeFrame(_ data: Data) -> (opcode: UInt8, payload: Data)? {
        guard data.count >= 2 else {
            return nil
        }

        let opcode = data[0] & 0x0F
        let masked = (data[1] & 0x80) != 0
        var payloadLength = Int(data[1] & 0x7F)
        var offset = 2

        if payloadLength == 126 {
            guard data.count >= 4 else {
                return nil
            }

            payloadLength = Int(data[2]) << 8 | Int(data[3])
            offset = 4
        } else if payloadLength == 127 {
            guard data.count >= 10 else {
                return nil
            }

            payloadLength = 0
            for index in 2..<10 {
                payloadLength = (payloadLength << 8) | Int(data[index])
            }
            offset = 10
        }

        if payloadLength > Self.maxFramePayloadBytes {
            connection.cancel()
            return nil
        }

        var maskKey = [UInt8]()
        if masked {
            guard data.count >= offset + 4 else {
                return nil
            }

            maskKey = Array(data[offset..<(offset + 4)])
            offset += 4
        }

        guard data.count >= offset + payloadLength else {
            return nil
        }

        let payload = Data(data[offset..<(offset + payloadLength)])
        guard masked else {
            return (opcode, payload)
        }

        let unmasked = Data(payload.enumerated().map { index, byte in
            byte ^ maskKey[index % 4]
        })

        return (opcode, unmasked)
    }

    private enum SignedPayloadResult {
        case valid(Data)
        case signatureMismatch
        case malformed
    }

    private func unwrapAndVerifySignedPayload(_ data: Data) -> SignedPayloadResult {
        guard let envelope = parseSignedEnvelope(data) else {
            return .malformed
        }

        if verifyHMAC(payload: envelope.payloadData, signature: envelope.signatureData) {
            return .valid(envelope.payloadData)
        }

        return .signatureMismatch
    }

    private func verifyHMAC(payload: Data, signature: Data) -> Bool {
        let expectedMAC = HMAC<SHA256>.authenticationCode(for: payload, using: hmacKey)
        return Data(expectedMAC) == signature
    }

    private func parseSignedEnvelope(_ data: Data) -> (payloadData: Data, signatureData: Data)? {
        guard let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any],
              json["p"] != nil,
              let signatureBase64 = json["s"] as? String,
              let signatureData = Data(base64Encoded: signatureBase64),
              let payloadData = extractPayloadJSONData(from: data) else {
            return nil
        }

        return (payloadData, signatureData)
    }

    private func extractPayloadJSONData(from frameData: Data) -> Data? {
        guard let text = String(data: frameData, encoding: .utf8) else {
            return nil
        }

        guard let payloadRange = topLevelJSONValueRange(forKey: "p", in: text) else {
            return nil
        }

        let payloadJSON = text[payloadRange]
        return Data(payloadJSON.utf8)
    }

    private func topLevelJSONValueRange(forKey targetKey: String, in text: String) -> Range<String.Index>? {
        var index = text.startIndex
        skipWhitespace(in: text, index: &index)
        guard index < text.endIndex, text[index] == "{" else {
            return nil
        }

        index = text.index(after: index)

        while index < text.endIndex {
            skipWhitespace(in: text, index: &index)
            guard index < text.endIndex else { return nil }
            if text[index] == "}" {
                return nil
            }

            guard let key = parseJSONString(in: text, index: &index) else {
                return nil
            }

            skipWhitespace(in: text, index: &index)
            guard index < text.endIndex, text[index] == ":" else {
                return nil
            }
            index = text.index(after: index)
            skipWhitespace(in: text, index: &index)

            let valueStart = index
            guard let valueEnd = parseJSONValueEnd(in: text, from: index) else {
                return nil
            }
            index = valueEnd

            if key == targetKey {
                return valueStart..<valueEnd
            }

            skipWhitespace(in: text, index: &index)
            guard index < text.endIndex else { return nil }
            if text[index] == "," {
                index = text.index(after: index)
                continue
            }
            if text[index] == "}" {
                return nil
            }
            return nil
        }

        return nil
    }

    private func parseJSONValueEnd(in text: String, from start: String.Index) -> String.Index? {
        guard start < text.endIndex else {
            return nil
        }

        let char = text[start]
        if char == "\"" {
            var cursor = text.index(after: start)
            var isEscaped = false
            while cursor < text.endIndex {
                let current = text[cursor]
                if isEscaped {
                    isEscaped = false
                } else if current == "\\" {
                    isEscaped = true
                } else if current == "\"" {
                    return text.index(after: cursor)
                }
                cursor = text.index(after: cursor)
            }
            return nil
        }

        if char == "{" || char == "[" {
            var cursor = start
            var depth = 0
            var inString = false
            var isEscaped = false

            while cursor < text.endIndex {
                let current = text[cursor]

                if inString {
                    if isEscaped {
                        isEscaped = false
                    } else if current == "\\" {
                        isEscaped = true
                    } else if current == "\"" {
                        inString = false
                    }
                } else {
                    if current == "\"" {
                        inString = true
                    } else if current == "{" || current == "[" {
                        depth += 1
                    } else if current == "}" || current == "]" {
                        depth -= 1
                        if depth == 0 {
                            return text.index(after: cursor)
                        }
                    }
                }

                cursor = text.index(after: cursor)
            }
            return nil
        }

        var cursor = start
        while cursor < text.endIndex {
            let current = text[cursor]
            if current == "," || current == "}" || current.isWhitespace {
                return cursor
            }
            cursor = text.index(after: cursor)
        }
        return cursor
    }

    private func parseJSONString(in text: String, index: inout String.Index) -> String? {
        guard index < text.endIndex, text[index] == "\"" else {
            return nil
        }

        let start = index
        var cursor = text.index(after: index)
        var isEscaped = false
        while cursor < text.endIndex {
            let current = text[cursor]
            if isEscaped {
                isEscaped = false
            } else if current == "\\" {
                isEscaped = true
            } else if current == "\"" {
                let end = text.index(after: cursor)
                let stringSlice = text[start..<end]
                let data = Data(stringSlice.utf8)
                guard let parsed = try? JSONSerialization.jsonObject(with: data) as? String else {
                    return nil
                }
                index = end
                return parsed
            }
            cursor = text.index(after: cursor)
        }
        return nil
    }

    private func skipWhitespace(in text: String, index: inout String.Index) {
        while index < text.endIndex, text[index].isWhitespace {
            index = text.index(after: index)
        }
    }

    private func shouldRateLimit() -> Bool {
        let now = Date()
        if now.timeIntervalSince(windowStart) > Self.rateLimitWindowSeconds {
            windowStart = now
            commandCount = 0
        }

        commandCount += 1
        return commandCount > Self.maxCommandsPerWindow
    }
}
