<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, interactive-widget=resizes-content" />
    <meta name="version" content="APP_VERSION" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="iControl" />
    <meta name="theme-color" content="#0b1220" />
    <title>iControl</title>
    <style>
      :root {
        --color-bg: #0b1220;
        --color-text: #e5e7eb;
        --color-text-muted: #c1cbda;
        --color-button: #18223b;
        --color-button-active: #283861;
        --color-border: rgba(71, 85, 105, 0.35);
        --color-border-accent: rgba(71, 85, 105, 0.5);
        --radius: 1.25rem;
        --radius-lg: 2.4rem;
        --gap: 0.65rem;
        --padding: 0.9rem;
        color-scheme: dark;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--color-bg);
        user-select: none;
        color: var(--color-text);
      }
      html {
        width: 100%;
        height: 100%;
        background-color: var(--color-bg);
      }
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        -webkit-user-select: none;
        -webkit-touch-callout: none;
        touch-action: manipulation;
      }
      .hidden {
        display: none !important;
      }
      textarea,
      input {
        user-select: text;
        -webkit-user-select: text;
        touch-action: auto;
      }
      body.vertical-rl {
        writing-mode: vertical-rl;
      }
      body {
        margin: 0;
        block-size: 100%;
        inline-size: 100%;
        overscroll-behavior: none;
        overflow: hidden;
        display: flex;
        align-items: center;
        flex-direction: column;
        padding: 0;
        position: relative;
        transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        background: radial-gradient(circle at top, rgba(5, 2, 59, 0.6), transparent 38%), linear-gradient(180deg, var(--color-bg), #020617);
      }
      body.drawer-open {
        transform: translateX(320px);
      }
      body.vertical-rl.drawer-open {
        transform: translateY(320px);
      }
      body.vertical-rl svg {
        transform: rotate(90deg);
        transform-origin: center center;
      }
      header,
      main {
        margin: 0;
        padding: 0.5rem;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        inline-size: 100%;
        pointer-events: none;
      }
      header > * {
        pointer-events: auto;
      }
      main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--gap);
        min-block-size: 0;
        container-type: size;
        inline-size: 100%;
      }
      .header-button {
        inline-size: 36px;
        block-size: 36px;
      }
      h1 {
        margin: 0;
        font-size: 1.4rem;
        line-height: 1;
        font-weight: 500;
      }
      .connection-status {
        background-color: color-mix(in srgb, currentColor 20%, transparent);
        line-height: 0.6;
        block-size: 24px;
        aspect-ratio: 1;
        border-radius: 50%;
      }
      .dot {
        block-size: 6px;
        aspect-ratio: 1;
        border-radius: 3px;
        background-color: currentColor;
      }
      p {
        margin: 0;
      }
      .flex {
        display: flex;
        justify-content: center;
        align-items: center;
      }
      #tab-wrapper {
        padding: var(--padding);
        border-radius: var(--radius-lg);
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--color-border);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(10px);
        max-inline-size: 42rem;
        inline-size: 100%;
        order: 2;
      }
      .tab-title-wrapper {
        margin-block-end: 0.75rem;
        max-inline-size: 100%;
        overflow: hidden;
      }
      .tab-title {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        transition: all 0.2s ease;
        line-height: 1.2rem;
        border-block-end: 2px solid transparent;
        padding: 0 var(--gap) 0.5rem var(--gap);
        cursor: pointer;
      }
      .tab-title.active {
        border-block-end: 2px solid var(--color-text);
        color: var(--color-text);
      }
      #touchpad-wrapper {
        flex: 1;
        min-block-size: 0;
        max-inline-size: 42rem;
        inline-size: 100%;
        border-radius: var(--radius-lg);
        background: linear-gradient(180deg, rgba(25, 42, 96, 0.25), rgba(0, 0, 0, 0.25));
        border: 1px solid var(--color-border-accent);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        transition: all 0.3s ease-in-out;
        order: 1;
      }
      #touchpad {
        flex: 1;
        user-select: none;
        touch-action: none;
      }

      #cursorPad {
        touch-action: none;
      }
      #touchpad.drag-mode {
        background: rgba(180, 100, 255, 0.08);
      }
      #cursorPad.select-mode {
        background: rgba(100, 150, 255, 0.2);
      }
      #touchpad-buttons {
        flex: 0 0 48px;
        display: flex;
        gap: 4px;
        align-items: stretch;
      }

      @container (max-block-size: 82px) {
        #touchpad-wrapper:not(:has(~ .keyboard.mini)) #touchpad {
          flex: 0;
          margin-block-end: 0;
        }
        #touchpad-wrapper:not(:has(~ .keyboard.mini)) #touchpad-buttons {
          flex: 1;
        }
      }
      @container (max-block-size: 340px) {
        #touchpad-wrapper:not(:has(~ .keyboard.mini)) {
          display: none;
        }
      }

      #touchpad-buttons button {
        border-radius: 0;
      }
      #touchpad-buttons > :first-child,
      #touchpad-buttons > :last-child {
        flex: 1;
      }
      #touchpad-buttons > :nth-child(2) {
        inline-size: 80px;
        flex-shrink: 0;
      }
      button {
        inline-size: 100%;
        border: 0;
        border-radius: var(--radius);
        display: flex;
        align-items: center;
        justify-content: center;
        font: inherit;
        background: var(--color-button);
        color: var(--color-text-muted);
        cursor: pointer;
        transition: inline-size 0.2s ease;
        font-size: 12px;
        position: relative;
      }
      .btn-label {
        position: absolute;
        inset-block-end: 4px;
        font-size: 8px;
        opacity: 0.4;
        letter-spacing: 0.001em;
        pointer-events: none;
        white-space: nowrap;
        line-height: 1;
      }
      button.active,
      button:active {
        background: var(--color-button-active);
        color: var(--color-text);
      }
      .grid {
        display: grid;
        gap: var(--gap);
      }
      .grid-3 {
        grid-template-columns: repeat(3, 1fr);
      }
      .grid-4 {
        grid-template-columns: repeat(4, 1fr);
      }
      .col-2 {
        grid-column: span 2;
      }
      .row-2 {
        grid-row: span 2;
      }
      .col-3 {
        grid-column: span 3;
      }
      .row-3 {
        grid-row: span 3;
      }
      .col-4 {
        grid-column: span 4;
      }
      .row-4 {
        grid-row: span 4;
      }
      .tab {
        max-inline-size: 480px;
        min-block-size: 280px;
        margin: auto;
      }
      .tab > * {
        min-block-size: 60px;
      }
      .ipod-wheel {
        position: relative;
        writing-mode: horizontal-tb;
        inline-size: 220px;
        block-size: 220px;
        margin: 0 auto 0.75rem;
        border-radius: 50%;
        background: radial-gradient(circle at 40% 40%, rgba(69, 85, 134, 0.25), rgba(0, 0, 0, 0.25));
        border: 2px solid var(--color-border-accent);
        box-shadow:
          inset 0 2px 8px rgba(0, 0, 0, 0.6),
          0 8px 20px rgba(0, 0, 0, 0.4);
      }
      .wheel-button,
      .wheel-center {
        position: absolute;
        border-radius: 50%;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        color: var(--color-text);
        padding: 0;
      }
      .wheel-button {
        inline-size: 72px;
        block-size: 72px;
      }
      .wheel-button:active {
        background: var(--color-button-active);
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);
      }
      .wheel-center {
        inset-block-start: 50%;
        inset-inline-start: 50%;
        transform: translate(-50%, -50%);
        inline-size: 72px;
        block-size: 72px;
        border: 2px solid rgba(71, 85, 105, 0.6);
        background: var(--color-button);
        box-shadow:
          inset 0 2px 4px rgba(0, 0, 0, 0.4),
          0 4px 8px rgba(0, 0, 0, 0.3);
      }
      .wheel-center:active {
        background: #0f1729;
        box-shadow:
          inset 0 3px 6px rgba(0, 0, 0, 0.6),
          0 2px 4px rgba(0, 0, 0, 0.3);
      }
      .wheel-button-up {
        inset-block-start: 0;
        inset-inline-start: 50%;
        transform: translateX(-50%);
      }
      .wheel-button-down {
        inset-block-end: 0;
        inset-inline-start: 50%;
        transform: translateX(-50%);
      }
      .wheel-button-left {
        inset-inline-start: 0;
        inset-block-start: 50%;
        transform: translateY(-50%);
      }
      .wheel-button-right {
        inset-inline-end: 0;
        inset-block-start: 50%;
        transform: translateY(-50%);
      }
      .slider {
        position: relative;
        background: var(--color-button);
        border-radius: var(--radius);
        overflow: hidden;
        touch-action: none;
      }
      .slider-fill {
        position: absolute;
        inset-block-end: 0;
        inline-size: 100%;
        background: var(--color-button-active);
      }
      .slider-icon {
        position: absolute;
        inset-block-end: 20px;
        inset-inline-start: 50%;
        transform: translateX(-50%);
        pointer-events: none;
        z-index: 5;
      }
      body.vertical-rl .slider-icon {
        transform: translateY(-50%);
      }
      textarea,
      input {
        inline-size: 100%;
        block-size: 100%;
        padding: 0.75rem;
        border-radius: var(--radius);
        border: 1px solid var(--color-border);
        background: var(--color-button);
        color: var(--color-text);
        font: inherit;
        resize: none;
      }
      /* ── Settings Drawer ── */
      #drawer-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        background-color: black;
        opacity: 0.6;
      }
      #settings-drawer {
        position: fixed;
        inset-block-start: 0;
        inset-inline-start: 0;
        block-size: 100%;
        inline-size: 320px;
        background: radial-gradient(circle at top, rgba(5, 2, 59, 0.6), transparent 38%), linear-gradient(180deg, var(--color-bg), #020617);
        border-inline-end: 1px solid var(--color-border);
        z-index: 101;
        transform: translateX(-100%);
        overflow-block: auto;
        padding: var(--padding);
      }
      body.vertical-rl #settings-drawer {
        transform: translateY(-100%);
      }
      #drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      #drawer-close {
        inline-size: 36px;
        block-size: 36px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .drawer-section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .drawer-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-block-start: 0.5rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        line-height: 1.2rem;
        margin-block-start: 24px;
        margin-block-end: 12px;
      }
      .drawer-value {
        font-variant-numeric: tabular-nums;
        color: var(--color-text);
      }
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        inline-size: 100%;
        block-size: 4px;
        border-radius: 2px;
        background: var(--color-button-active);
        outline: none;
        cursor: pointer;
        border: none;
        padding: 0;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        inline-size: 20px;
        block-size: 20px;
        border-radius: 50%;
        background: var(--color-text);
        cursor: pointer;
      }
      .keyboard {
        display: flex;
        flex-direction: column;
        gap: 1px;
        inline-size: 100%;
        --key-width: calc(calc(min(100vi, 1920px) - 14px) / 14.5);
        --key-height: 48px;
        transition: all 1s ease-in-out;
        overflow: hidden;
        max-inline-size: 1920px;
        block-size: auto;
        order: 3;
      }
      .keyboard.swapped {
        order: 0;
      }
      .keyboard > .row {
        display: flex;
        justify-content: center;
        gap: 1px;
      }
      .keyboard.mini {
        block-size: var(--key-height);
      }
      .keyboard .key {
        inline-size: var(--key-width);
        block-size: var(--key-height);
        padding: 8px;
        border: none;
        border-radius: 2px;
        font-size: 12px;
        cursor: pointer;
        user-select: none;
        transition: all 0.1s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
      }
      .keyboard .key.letter {
        text-transform: uppercase;
      }
      .keyboard .key.label {
        flex-direction: column-reverse;
        justify-content: flex-start;
      }
      .keyboard .key.label:has(> :nth-child(2)) {
        justify-content: space-between;
      }
      .keyboard .key.label.right {
        align-items: flex-end;
      }
      .keyboard .key.label.left {
        align-items: flex-start;
      }
      .keyboard .key.ghost {
        opacity: 0;
      }
      .keyboard .key.cmd {
        inline-size: calc(var(--key-width) * 1.25);
      }
      .keyboard .key.half {
        inline-size: calc(var(--key-width) * 0.5);
      }
      .keyboard .key.one-and-half {
        inline-size: calc(var(--key-width) * 1.5);
      }
      .keyboard .key.two {
        inline-size: calc(var(--key-width) * 2);
      }
      .keyboard .key.two-and-half {
        inline-size: calc(var(--key-width) * 2.5);
      }
      .keyboard .key.fluid {
        inline-size: auto;
        flex: 1;
      }
      .keyboard .key:active {
        transform: translateY(2px);
      }
      body.vertical-rl .keyboard .key:active {
        transform: translateX(-2px);
      }
      /* Letter case driven by keyboard state */
      .keyboard.shift-active .key.letter,
      .keyboard.caps-active .key.letter {
        text-transform: uppercase;
      }

      /* Override default uppercase on .letter when neither active */
      .keyboard:not(.shift-active):not(.caps-active) .key.letter {
        text-transform: lowercase;
      }
      .keyboard .key.dual {
        flex-direction: column;
        justify-content: space-between;
      }
      .keyboard .key.dual .top {
        font-size: 10px;
        color: #71717a;
        line-height: 1;
        font-weight: inherit;
      }
      .keyboard .key.dual .bottom {
        font-size: 12px;
        font-weight: 500;
        line-height: 1;
        color: inherit;
      }
      .keyboard.shift-active .key.dual .top {
        font-size: 12px;
        font-weight: 500;
        color: inherit;
      }
      .keyboard.shift-active .key.dual .bottom {
        font-size: 10px;
        color: #71717a;
        font-weight: inherit;
      }
      .keyboard .fn .key.dual .top {
        font-size: 12px;
        color: inherit;
        font-weight: 500;
      }
      .keyboard .fn .key.dual .bottom {
        font-size: 10px;
        font-weight: inherit;
        color: #71717a;
      }
      .keyboard .key-label-short {
        display: none;
      }
      .keyboard .key-label-long {
        display: inline;
      }
      @media screen and (max-width: 767px) {
        .keyboard .key-label-long {
          display: none;
        }
        .keyboard .key-label-short {
          display: inline;
        }
      }
      @media screen and (min-width: 820px) and (min-height: 480px) {
        .keyboard {
          --key-height: 72px;
        }
        .keyboard .key {
          font-size: 16px;
          border-radius: 12px;
          border: 1px solid #020617;
        }
        .keyboard .key.dual {
          padding: 0.75rem;
        }
        .keyboard .key.dual .top {
          font-size: 14px;
        }
        .keyboard .key.dual .bottom {
          font-size: 16px;
        }
        .keyboard .fn .key.dual .top {
          font-size: 16px;
        }
        .keyboard .fn .key.dual .bottom {
          font-size: 14px;
        }
      }
      @media screen and (min-width: 1280px) {
        .keyboard {
          --key-height: 84px;
        }
        .keyboard .key {
          font-size: 18px;
          border-radius: 16px;
          border: 2px solid #020617;
        }
        .keyboard .key.dual {
          padding: 1rem;
        }
        .keyboard .key.dual .top {
          font-size: 16px;
        }
        .keyboard .key.dual .bottom {
          font-size: 20px;
        }
        .keyboard .fn .key.dual .top {
          font-size: 20px;
        }
        .keyboard .fn .key.dual .bottom {
          font-size: 16px;
        }
      }
      /* ── Auth Modal ── */
      #auth-modal {
        position: fixed;
        inset: 0;
        padding: 1rem;
        z-index: 200;
        background: var(--color-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
      }
      #auth-modal-inner {
        padding: 1rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        min-inline-size: 320px;
      }
      #auth-modal-title {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        opacity: 0.85;
        margin-block-end: 1rem;
      }
      #auth-token-input {
        display: flex;
        gap: 0.6rem;
        justify-content: center;
      }
      .otp-digit {
        font-size: 2rem;
        font-weight: 300;
        text-align: center;
        text-transform: uppercase;
        font-family: monospace;
        border-width: 2px;
        inline-size: 4rem;
        block-size: 4rem;
        padding: 0;
      }
      .otp-digit:focus {
        border-color: var(--color-text-muted);
        outline: none;
      }
      #auth-error-message {
        color: #f87171;
        font-size: 0.85rem;
      }
      #auth-submit {
        margin-block-start: 1rem;
        font-size: 0.9em;
        font-weight: 700;
        block-size: 3.2rem;
        background-color: var(--color-button-active);
      }
      #or {
        font-size: 0.6em;
        opacity: 0.75;
      }
      #auth-request {
        font-size: 0.8em;
        color: var(--color-text-muted);
        background: transparent;
        block-size: 3.2rem;
        border: 2px solid var(--color-button);
      }
    </style>
  </head>
  <body>
